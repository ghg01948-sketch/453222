-- Функция для создания летящих цифр
local function createDigitalRain(parent)
    local rainFrame = Instance.new("Frame")
    rainFrame.Name = "DigitalRain"
    rainFrame.Size = UDim2.new(1, 0, 1, 0)
    rainFrame.BackgroundTransparency = 1
    rainFrame.Parent = parent
    rainFrame.ZIndex = 10
    
    for i = 1, 20 do
        local column = Instance.new("TextLabel")
        column.Size = UDim2.new(0, 20, 1, 0)
        column.Position = UDim2.new(i * 0.05, 0, 0, 0)
        column.BackgroundTransparency = 1
        column.Text = ""
        column.TextColor3 = CurrentColor
        column.TextSize = 14
        column.Font = Enum.Font.Code
        column.Parent = rainFrame
        column.ZIndex = 10
        
        local content = {}
        for j = 1, 20 do
            content[j] = string.char(math.random(48, 57)) -- Случайные цифры
        end
        
        local yPos = 0
        local speed = math.random(20, 50) / 100
        
        RunService.Heartbeat:Connect(function(dt)
            if not parent.Visible then return end
            yPos = yPos + speed * 100 * dt
            if yPos > 1 then yPos = 0 end
            
            local text = ""
            for j = 1, 10 do
                local pos = (yPos + j * 0.05) % 1
                local alpha = math.max(0, 1 - math.abs(pos - 0.5) * 4)
                if alpha > 0.1 then
                    text = text .. content[math.random(1, 20)] .. "\n"
                else
                    text = text .. " \n"
                end
            end
            column.Text = text
        end)
    end
end


local isMenuOpen = false
local allPlaces = {}
local filteredPlaces = {}
local isLoading = false

local MAX_RETRIES = 69
local RETRY_DELAY = 0.5

local function getUniversePlaces()
    local places = {}
    
    local retryCount = 0
    local success = false
    local gamePlaces
    
    while retryCount < MAX_RETRIES and not success do
        retryCount = retryCount + 1
        local ok, result = pcall(function()
            return AssetService:GetGamePlacesAsync()
        end)
        
        if ok then
            success = true
            gamePlaces = result
        else
            task.wait(RETRY_DELAY)
        end
    end
    
    if not success then
        local universeId = game.GameId
        
        if universeId > 0 then
            local url = "https://games.roblox.com/v2/games/" .. universeId .. "/games?accessFilter=2&limit=100&sortOrder=Asc"
            
            local ok, response = pcall(function()
                return HttpService:GetAsync(url)
            end)
            
            if ok then
                local data = HttpService:JSONDecode(response)
                if data and data.data then
                    for _, gameData in ipairs(data.data) do
                        if gameData.id and gameData.name then
                            table.insert(places, {
                                PlaceId = gameData.id,
                                Name = gameData.name
                            })
                        end
                    end
                end
            end
        end
        
        return places
    end
    
    while true do
        for _, place in ipairs(gamePlaces:GetCurrentPage()) do
            if place and place.PlaceId then
                table.insert(places, {
                    PlaceId = place.PlaceId,
                    Name = place.Name or "Unnamed Place"
                })
            end
        end
        
        if gamePlaces.IsFinished then
            break
        end
        
        local ok = pcall(function()
            gamePlaces:AdvanceToNextPageAsync()
        end)
        
        if not ok then
            break
        end
    end
    
    return places
end

local function filterPlaces(searchText)
    filteredPlaces = {}
    
    if searchText == "" or searchText == nil then
        for i, place in ipairs(allPlaces) do
            table.insert(filteredPlaces, {
                PlaceId = place.PlaceId,
                Name = place.Name,
                index = i
            })
        end
    else
        local searchLower = string.lower(searchText)
        
        for i, place in ipairs(allPlaces) do
            local nameLower = string.lower(place.Name)
            local placeIdStr = tostring(place.PlaceId)
            
            if string.find(nameLower, searchLower, 1, true) or 
               string.find(placeIdStr, searchText, 1, true) then
                table.insert(filteredPlaces, {
                    PlaceId = place.PlaceId,
                    Name = place.Name,
                    index = i
                })
            end
        end
    end
    
    return filteredPlaces
end


    }
    
    for i, pos in ipairs(cornerPositions) do
        local corner = Instance.new("TextButton")
        corner.Name = "ResizeCorner" .. i
        corner.Size = pos.Size
        corner.Position = pos.Position
        corner.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        corner.BackgroundTransparency = 0.5
        corner.BorderSizePixel = 1
        corner.BorderColor3 = CurrentColor
        corner.Text = i == 4 and "↘" or (i == 3 and "↙" or (i == 2 and "↗" or "↖"))
        corner.TextColor3 = CurrentColor
        corner.TextSize = 8
        corner.Font = Enum.Font.Code
        corner.Parent = MainFrame
        corner.ZIndex = 10
        
        -- Изменяем видимость при наведении
        corner.MouseEnter:Connect(function()
            animate(corner, {BackgroundTransparency = 0, BorderColor3 = CurrentColor}, 0.1)
        end)
        
        corner.MouseLeave:Connect(function()
            animate(corner, {BackgroundTransparency = 0.5, BorderColor3 = DarkBorderColor}, 0.1)
        end)
        
        -- Функционал изменения размера
        corner.MouseButton1Down:Connect(function(input)
            Resizing = true
            ResizeDirection = i
            local startPos = input.Position
            local startSize = MainFrame.Size
            local startX, startY = startSize.X.Offset, startSize.Y.Offset
            
            local connection
            connection = UserInputService.InputChanged:Connect(function(input)
                if Resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local delta = input.Position - startPos
                    local newWidth = startX
                    local newHeight = startY
                    
                    if i == 1 or i == 3 then -- левая сторона
                        newWidth = math.max(MinSize.X, startX - delta.X)
                    elseif i == 2 or i == 4 then -- правая сторона
                        newWidth = math.max(MinSize.X, startX + delta.X)
                    end
                    
                    if i == 1 or i == 2 then -- верхняя сторона
                        newHeight = math.max(MinSize.Y, startY - delta.Y)
                    elseif i == 3 or i == 4 then -- нижняя сторона
                        newHeight = math.max(MinSize.Y, startY + delta.Y)
                    end
                    
                    MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
                end
            end)
            
            local releaseConn
            releaseConn = UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    Resizing = false
                    ResizeDirection = nil
                    connection:Disconnect()
                    releaseConn:Disconnect()
                end
            end)
        end)
        
        table.insert(resizeCorners, corner)
    end
    
    -- Dragging для перемещения всего окна
    local dragging = false
    local dragStart, startPos
    
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and not Resizing then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            titleBar.BorderColor3 = CurrentColor
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            titleBar.BorderColor3 = DarkBorderColor
        end
    end)
    
    -- Hide/show functionality с матричным эффектом

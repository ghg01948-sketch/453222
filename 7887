            function DropdownObject:NewSlider(sliderName, description, min, max, default, callback)
                local btnY = contentY
                
                local sliderFrame = Instance.new("Frame")
                sliderFrame.Size = UDim2.new(1, -20, 0, 70)
                sliderFrame.Position = UDim2.new(0, 10, 0, btnY)
                sliderFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                sliderFrame.BackgroundTransparency = 0.1
                sliderFrame.BorderSizePixel = 0
                sliderFrame.ZIndex = 16
                sliderFrame.Parent = dropdownContent
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = "$ " .. sliderName
                nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Белый
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.ZIndex = 17
                nameLabel.Parent = sliderFrame
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -20, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = "// " .. (description or "")
                descLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                descLabel.TextSize = 12
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.ZIndex = 17
                descLabel.Parent = sliderFrame
                
                local valueLabel = Instance.new("TextLabel")
                valueLabel.Size = UDim2.new(0, 50, 0, 20)
                valueLabel.Position = UDim2.new(1, -60, 0, 28)
                valueLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                valueLabel.BorderSizePixel = 0
                valueLabel.Text = "[" .. tostring(default or min) .. "]"
                valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Белый
                valueLabel.TextSize = 12
                valueLabel.Font = Enum.Font.Code
                valueLabel.ZIndex = 17
                valueLabel.Parent = sliderFrame
                
                local sliderBg = Instance.new("Frame")
                sliderBg.Size = UDim2.new(1, -80, 0, 10)
                sliderBg.Position = UDim2.new(0, 10, 0, 50)
                sliderBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                sliderBg.BorderSizePixel = 0
                sliderBg.ZIndex = 17
                sliderBg.Parent = sliderFrame
                
                local sliderFill = Instance.new("Frame")
                sliderFill.Size = UDim2.new(0, 0, 1, 0)
                sliderFill.BackgroundColor3 = Color3.fromRGB(200, 200, 200) -- Светло-серый
                sliderFill.BorderSizePixel = 0
                sliderFill.ZIndex = 18
                sliderFill.Parent = sliderBg
                
                local sliderButton = Instance.new("TextButton")
                sliderButton.Size = UDim2.new(1, 0, 1, 0)
                sliderButton.BackgroundTransparency = 1
                sliderButton.Text = ""
                sliderButton.ZIndex = 18
                sliderButton.Parent = sliderBg
                
                local currentValue = default or min
                local dragging = false
                
                local function updateSlider(input)
                    local mousePos = input.Position
                    local absPos = sliderBg.AbsolutePosition
                    local absSize = sliderBg.AbsoluteSize.X
                    
                    local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                    local percent = relativeX / absSize
                    
                    currentValue = math.floor(min + (max - min) * percent)
                    currentValue = math.clamp(currentValue, min, max)
                    
                    TweenService:Create(sliderFill, TweenInfo.new(0.1), {Size = UDim2.new(percent, 0, 1, 0)}):Play()
                    valueLabel.Text = "[" .. tostring(currentValue) .. "]"
                    
                    if callback then
                        local success, err = pcall(function() callback(currentValue) end)
                        if not success then warn("Error in dropdown slider callback: " .. err) end
                    end
                end
                
                if default then
                    local percent = (default - min) / (max - min)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = "[" .. tostring(default) .. "]"
                    if callback then pcall(function() callback(default) end) end
                end
                
                sliderButton.MouseButton1Down:Connect(function(input)
                    dragging = true
                    updateSlider(input)
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                contentY = contentY + 75
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    updateDropdownPosition()
                end
            end
            
            return DropdownObject
        end
        

function Library:NewTab(name)
    -- Создаем контейнер для вкладок если его нет
    local tabContainer = ColumnsFrame:FindFirstChild("TabContainer")
    if not tabContainer then
        tabContainer = Instance.new("Frame")
        tabContainer.Name = "TabContainer"
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.ZIndex = 11
        tabContainer.Parent = ColumnsFrame
    end
    
    -- Создаем фрейм для этой вкладки
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.Position = UDim2.new(0, 0, 0, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel = 0
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 8
    tabFrame.ScrollBarImageColor3 = Color3.fromRGB(150, 150, 150) -- Серый
    tabFrame.ZIndex = 12
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false
    
    -- Контейнер для элементов внутри вкладки
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.ZIndex = 13
    container.Parent = tabFrame
    
    -- Создаем кнопку вкладки
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -2)
        tabButton.Position = UDim2.new(0, (#TabButtons * 105 + 5), 0, 1)
        tabButton.BackgroundTransparency = 1
        tabButton.Text = "$ " .. name .. " $"
        tabButton.TextColor3 = (#TabButtons == 0) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
        tabButton.TextSize = 14
        tabButton.Font = Enum.Font.Code
        tabButton.BorderSizePixel = 0
        tabButton.ZIndex = 12
        tabButton.Parent = tabButtonContainer
        
        table.insert(TabButtons, tabButton)
        
        -- Если это первая вкладка, показываем её
        if #TabButtons == 1 then
            tabFrame.Visible = true
            local line = Instance.new("Frame")
            line.Size = UDim2.new(1, 0, 0, 2)
            line.Position = UDim2.new(0, 0, 1, -2)
            line.BackgroundColor3 = Color3.fromRGB(200, 200, 200) -- Светло-серый
            line.BorderSizePixel = 0
            line.ZIndex = 13
            line.Parent = tabButton
        end
        
        -- Обработчик клика по вкладке
        tabButton.MouseButton1Click:Connect(function()
            -- Глитч эффект при смене вкладки
            glitchEffect.Visible = true
            glitchEffect.Text = "$ ACCESSING " .. string.upper(name) .. " $"
            TweenService:Create(glitchEffect, TweenInfo.new(0.2), {BackgroundTransparency = 0.8}):Play()
            
            -- Скрываем все вкладки
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            -- Показываем выбранную вкладку
            tabFrame.Visible = true
            

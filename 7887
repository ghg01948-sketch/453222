                toggleBg.Size = UDim2.new(0, 50, 0, 24)
                toggleBg.Position = UDim2.new(1, -60, 0.5, -12)
                toggleBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                toggleBg.BorderSizePixel = 2
                toggleBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                toggleBg.Parent = toggleFrame
                
                local toggleIndicator = Instance.new("Frame")
                toggleIndicator.Size = UDim2.new(0, 20, 0, 16)
                toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                toggleIndicator.BorderSizePixel = 1
                toggleIndicator.BorderColor3 = Color3.fromRGB(140, 140, 140)
                toggleIndicator.Parent = toggleBg
                
                local toggleState = false
                ToggleStates[toggleId] = false
                
                local function updateToggle()
                    if toggleState then
                        toggleIndicator.BackgroundColor3 = CurrentColor
                        toggleIndicator.Position = UDim2.new(1, -22, 0.5, -8)
                    else
                        toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                        toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                    end
                end
                
                local toggleButton = Instance.new("TextButton")
                toggleButton.Size = UDim2.new(1, 0, 1, 0)
                toggleButton.BackgroundTransparency = 1
                toggleButton.Text = ""
                toggleButton.Parent = toggleFrame
                
                toggleButton.MouseButton1Click:Connect(function()
                    toggleState = not toggleState
                    ToggleStates[toggleId] = toggleState
                    updateToggle()
                    
                    if callback then
                        local success, err = pcall(function()
                            callback(toggleState)
                        end)
                        if not success then
                            warn("Error in dropdown toggle callback: " .. err)
                        end
                    end
                end)
                
                dropdownRef.contentY = dropdownRef.contentY + 55
                dropdownRef.content.Size = UDim2.new(1, 0, 0, dropdownRef.contentY)
                
                if dropdownRef.isOpen then
                    dropdownRef.frame.Size = UDim2.new(1, 0, 0, 50 + dropdownRef.contentY)
                end
                
                dropdownRef.updateAll()
            end
            
            -- Метод для добавления ползунка в дропдаун
            function SectionObject:NewDropdownSlider(sliderName, description, min, max, default, callback)
                local btnY = dropdownRef.contentY
                local sliderId = tostring(math.random(10000, 99999))
                
                local sliderFrame = Instance.new("Frame")
                sliderFrame.Size = UDim2.new(1, -20, 0, 70)
                sliderFrame.Position = UDim2.new(0, 10, 0, btnY)
                sliderFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                sliderFrame.BorderSizePixel = 1
                sliderFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                sliderFrame.Parent = dropdownRef.content
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = sliderName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = sliderFrame
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -20, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = description or ""
                descLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
                descLabel.TextSize = 12
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = sliderFrame
                
                -- Значение ползунка
                local valueLabel = Instance.new("TextLabel")
                valueLabel.Size = UDim2.new(0, 50, 0, 20)
                valueLabel.Position = UDim2.new(1, -60, 0, 28)
                valueLabel.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                valueLabel.BorderSizePixel = 1
                valueLabel.BorderColor3 = Color3.fromRGB(80, 80, 80)
                valueLabel.Text = tostring(default or min)
                valueLabel.TextColor3 = CurrentColor
                valueLabel.TextSize = 12
                valueLabel.Font = Enum.Font.Code
                valueLabel.Parent = sliderFrame
                
                -- Полоса ползунка
                local sliderBg = Instance.new("Frame")
                sliderBg.Size = UDim2.new(1, -80, 0, 10)
                sliderBg.Position = UDim2.new(0, 10, 0, 50)
                sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                sliderBg.BorderSizePixel = 1
                sliderBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                sliderBg.Parent = sliderFrame
                
                local sliderFill = Instance.new("Frame")
                sliderFill.Size = UDim2.new(0, 0, 1, 0)
                sliderFill.BackgroundColor3 = CurrentColor
                sliderFill.BorderSizePixel = 0
                sliderFill.Parent = sliderBg
                
                local sliderButton = Instance.new("TextButton")
                sliderButton.Size = UDim2.new(1, 0, 1, 0)
                sliderButton.BackgroundTransparency = 1
                sliderButton.Text = ""
                sliderButton.Parent = sliderBg
                
                local currentValue = default or min
                local dragging = false
                
                local function updateSlider(input)
                    local mousePos = input.Position
                    local absPos = sliderBg.AbsolutePosition
                    local absSize = sliderBg.AbsoluteSize.X
                    
                    local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                    local percent = relativeX / absSize
                    
                    currentValue = math.floor(min + (max - min) * percent)
                    if currentValue < min then currentValue = min end
                    if currentValue > max then currentValue = max end
                    
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(currentValue)
                    SliderValues[sliderId] = currentValue
                    
                    if callback then
                        local success, err = pcall(function()
                            callback(currentValue)
                        end)
                        if not success then
                            warn("Error in dropdown slider callback: " .. err)
                        end
                    end
                end
                
                if default then
                    local percent = (default - min) / (max - min)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(default)
                    SliderValues[sliderId] = default
                    
                    if callback then
                        pcall(function()
                            callback(default)
                        end)
                    end
                end
                
                sliderButton.MouseButton1Down:Connect(function(input)
                    dragging = true
                    updateSlider(input)
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                dropdownRef.contentY = dropdownRef.contentY + 75
                dropdownRef.content.Size = UDim2.new(1, 0, 0, dropdownRef.contentY)
                
                if dropdownRef.isOpen then
                    dropdownRef.frame.Size = UDim2.new(1, 0, 0, 50 + dropdownRef.contentY)
                end
                
                dropdownRef.updateAll()
            end
            
            tabData.YPosition = currentY + 50
            tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, tabData.YPosition + 10)
        end
        
        -- Текстовый блок
        function SectionObject:NewTextBlock(text)
            local currentY = tabData.YPosition
            
            local lines = #text:split("\n")
            local height = math.max(60, 40 + lines * 20)
            
            local textFrame = Instance.new("Frame")
            textFrame.Size = UDim2.new(1, 0, 0, height)
            textFrame.Position = UDim2.new(0, 0, 0, currentY)
            textFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            textFrame.BorderSizePixel = 2
            textFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            textFrame.Parent = container
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, -20, 1, -20)
            textLabel.Position = UDim2.new(0, 10, 0, 10)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = text or ""
            textLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            textLabel.TextSize = 14
            textLabel.Font = Enum.Font.Code
            textLabel.TextWrapped = true
            textLabel.TextXAlignment = Enum.TextXAlignment.Left
            textLabel.TextYAlignment = Enum.TextYAlignment.Top
            textLabel.Parent = textFrame
            
            tabData.YPosition = currentY + height + 10
            tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, tabData.YPosition + 10)
        end
        
        return SectionObject
    end
    
    return TabObject
end

function Library:GetToggleState(id)
    return ToggleStates[id] or false
end

function Library:GetSliderValue(id)
    return SliderValues[id] or 0
end

return Library

                TweenService:Create(BlurEffect, TweenInfo.new(0.3), {Size = 0}):Play()
                TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 250, 0, 55),
                    Position = UDim2.new(0.5, -125, 0.5, -27.5)
                }):Play()
            end
        end
    end)
    
    -- Функция обновления размеров табов
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end
        
        local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
        tabWidth = math.clamp(tabWidth, 85, 160)
        
        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, -4)
            tabBtn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10), 0, 2)
        end
    end
    
    tabContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
    
    return self
end

-- ===== КЛАСС TAB =====
function Library:NewTab(name)
    local tabContainer = ColumnsFrame:FindFirstChild("TabContentContainer") or ColumnsFrame:FindFirstChild("TabContainer")
    
    -- Создаем фрейм вкладки
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel = 0
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 4
    tabFrame.ScrollBarImageColor3 = Colors.Accent
    tabFrame.ScrollBarImageTransparency = 0.5
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false
    
    -- Контейнер элементов
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame
    
    -- Создаем кнопку вкладки
    local tabBar = MainFrame:FindFirstChild("InnerGlow"):FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -4)
        tabButton.Position = UDim2.new(0, (#TabButtons * 110 + 5), 0, 2)
        tabButton.BackgroundColor3 = (#TabButtons == 0) and Colors.Accent or Colors.Background4
        tabButton.BackgroundTransparency = (#TabButtons == 0) and 0.8 or 0
        tabButton.BorderSizePixel = 0
        tabButton.Text = name
        tabButton.TextColor3 = (#TabButtons == 0) and Colors.Text or Colors.TextDim
        tabButton.TextSize = 15
        tabButton.Font = Enum.Font.Code
        tabButton.Parent = tabButtonContainer
        tabButton.AutoButtonColor = false
        
        addCorners(tabButton, 6)
        
        table.insert(TabButtons, tabButton)
        
        -- Эффекты наведения
        tabButton.MouseEnter:Connect(function()
            if CurrentTab ~= tabButton then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = Colors.Background3,
                    TextColor3 = Colors.Text
                }):Play()
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if CurrentTab ~= tabButton then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = Colors.Background4,
                    TextColor3 = Colors.TextDim
                }):Play()
            end
        end)
        
        -- Если это первая вкладка, показываем её
        if #TabButtons == 1 then
            tabFrame.Visible = true
            CurrentTab = tabButton
        end
        
        -- Обработчик клика
        tabButton.MouseButton1Click:Connect(function()
            -- Скрываем все вкладки
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            -- Показываем выбранную
            tabFrame.Visible = true
            
            -- Анимируем кнопки
            for _, btn in ipairs(TabButtons) do
                TweenService:Create(btn, TweenInfo.new(0.3), {
                    BackgroundColor3 = Colors.Background4,
                    BackgroundTransparency = 0,
                    TextColor3 = Colors.TextDim
                }):Play()
            end
            
            TweenService:Create(tabButton, TweenInfo.new(0.3), {
                BackgroundColor3 = Colors.Accent,
                BackgroundTransparency = 0.8,
                TextColor3 = Colors.Text
            }):Play()
            

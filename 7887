-- Функции для редактора скриптов
local function openScriptEditor(buttonIndex)
    if isScriptEditorOpen then return end
    
    isScriptEditorOpen = true
    currentEditingButtonIndex = buttonIndex
    
    buttonNameBox.Text = savedButtonNames[buttonIndex]
    scriptTextBox.Text = savedScripts[savedButtonNames[buttonIndex]] or ""
    scriptEditorFrame.Visible = true
    
    scriptEditorFrame.Size = UDim2.new(0, 0, 0, 0)
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    tweenService:Create(scriptEditorFrame, tweenInfo, {
        Size = UDim2.new(0, 500, 0, 450)
    }):Play()
end

local function closeScriptEditor()
    if not isScriptEditorOpen then return end
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    tweenService:Create(scriptEditorFrame, tweenInfo, {
        Size = UDim2.new(0, 0, 0, 0)
    }):Play()
    
    task.wait(0.3)
    scriptEditorFrame.Visible = false
    isScriptEditorOpen = false
    currentEditingButtonIndex = nil
end

saveButton.MouseButton1Click:Connect(function()
    if currentEditingButtonIndex then
        local oldName = savedButtonNames[currentEditingButtonIndex]
        local newName = buttonNameBox.Text
        
        if newName ~= "" then
            savedScripts[newName] = scriptTextBox.Text
            savedButtonNames[currentEditingButtonIndex] = newName
            
            if oldName ~= newName then
                savedScripts[oldName] = nil
            end
        end
        closeScriptEditor()
    end
end)

cancelButton.MouseButton1Click:Connect(function()
    closeScriptEditor()
end)


                descLabel.BackgroundTransparency = 1
                descLabel.Text = description
                descLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
                descLabel.TextSize = 11
                descLabel.Font = Enum.Font.Gotham
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = dropdownFrame
            end

            local arrowLabel = Instance.new("TextLabel")
            arrowLabel.Size = UDim2.new(0, 30, 0, 20)
            arrowLabel.Position = UDim2.new(1, -40, 0, 12.5)
            arrowLabel.BackgroundTransparency = 1
            arrowLabel.Text = "▼"
            arrowLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            arrowLabel.TextSize = 12
            arrowLabel.Font = Enum.Font.Gotham
            arrowLabel.Parent = dropdownFrame

            local dropdownContent = Instance.new("Frame")
            dropdownContent.Name = "DropdownContent"
            dropdownContent.Size = UDim2.new(1, 0, 0, 0)
            dropdownContent.Position = UDim2.new(0, 0, 0, 45)
            dropdownContent.BackgroundTransparency = 1
            dropdownContent.Parent = dropdownFrame
            dropdownContent.Visible = false

            local isOpen = false
            local contentY = 0
            local baseY = elementY

            local function updateDropdownPosition()
                if isOpen then
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 45 + contentY)
                else
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 45)
                end

                local currentY = baseY + dropdownFrame.AbsoluteSize.Y
                local found = false

                for _, child in pairs(container:GetChildren()) do
                    if child == dropdownFrame then
                        found = true
                    elseif found and child:IsA("Frame") and child ~= dropdownFrame then
                        child.Position = UDim2.new(0, 0, 0, currentY)
                        currentY = currentY + child.AbsoluteSize.Y + 10
                    end
                end

                elementY = baseY + dropdownFrame.AbsoluteSize.Y
                tabFrame.CanvasSize = UDim2.new(0, 0, 0, currentY + 15)
            end

            local function toggleDropdown()
                isOpen = not isOpen
                arrowLabel.Text = isOpen and "▲" or "▼"
                dropdownContent.Visible = isOpen
                updateDropdownPosition()
            end

            dropdownButton.MouseButton1Click:Connect(toggleDropdown)

            elementY = elementY + 45

            local DropdownObject = {}

            function DropdownObject:NewButton(buttonName, callback)
                local btnFrame = Instance.new("Frame")
                btnFrame.Size = UDim2.new(1, -20, 0, 35)
                btnFrame.Position = UDim2.new(0, 10, 0, contentY)
                btnFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                btnFrame.BorderSizePixel = 0
                btnFrame.Parent = dropdownContent

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = buttonName
                nameLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                nameLabel.TextSize = 12
                nameLabel.Font = Enum.Font.Gotham
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = btnFrame

                local button = Instance.new("TextButton")
                button.Size = UDim2.new(1, 0, 1, 0)
                button.BackgroundTransparency = 1
                button.Text = ""
                button.Parent = btnFrame

                button.MouseEnter:Connect(function()
                    btnFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                end)

                button.MouseLeave:Connect(function()
                    btnFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                end)

                button.MouseButton1Click:Connect(function()
                    if callback then
                        pcall(callback)
                    end
                end)

                contentY = contentY + 40
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)

                if isOpen then
                    updateDropdownPosition()
                end
            end

            function DropdownObject:NewToggle(toggleName, callback)
                local toggleFrame = Instance.new("Frame")
                toggleFrame.Size = UDim2.new(1, -20, 0, 35)
                toggleFrame.Position = UDim2.new(0, 10, 0, contentY)
                toggleFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                toggleFrame.BorderSizePixel = 0
                toggleFrame.Parent = dropdownContent

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -50, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = toggleName
                nameLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                nameLabel.TextSize = 12
                nameLabel.Font = Enum.Font.Gotham
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = toggleFrame

                local toggleBg = Instance.new("Frame")
                toggleBg.Size = UDim2.new(0, 35, 0, 18)
                toggleBg.Position = UDim2.new(1, -45, 0.5, -9)
                toggleBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                toggleBg.BorderSizePixel = 0
                toggleBg.Parent = toggleFrame

                local toggleIndicator = Instance.new("Frame")
                toggleIndicator.Size = UDim2.new(0, 14, 0, 12)
                toggleIndicator.Position = UDim2.new(0, 2, 0.5, -6)
                toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                toggleIndicator.BorderSizePixel = 0
                toggleIndicator.Parent = toggleBg

                local toggleState = false

                local function updateToggle()
                    if toggleState then
                        toggleIndicator.BackgroundColor3 = CurrentColor
                        toggleIndicator.Position = UDim2.new(1, -16, 0.5, -6)
                    else
                        toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                        toggleIndicator.Position = UDim2.new(0, 2, 0.5, -6)
                    end
                end

                local toggleButton = Instance.new("TextButton")
                toggleButton.Size = UDim2.new(1, 0, 1, 0)
                toggleButton.BackgroundTransparency = 1
                toggleButton.Text = ""
                toggleButton.Parent = toggleFrame

                toggleButton.MouseButton1Click:Connect(function()
                    toggleState = not toggleState
                    updateToggle()
                    
                    if callback then
                        pcall(callback, toggleState)
                    end
                end)

                contentY = contentY + 40
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)

                if isOpen then
                    updateDropdownPosition()
                end
            end

            return DropdownObject
        end

        return SectionObject
    end

    return TabObject
end

return Library

-- Создание матричных частиц
local function createMatrixParticles(frame)
    local particleContainer = Instance.new("Frame")
    particleContainer.Name = "MatrixParticles"
    particleContainer.Size = UDim2.new(1, 0, 1, 0)
    particleContainer.BackgroundTransparency = 1
    particleContainer.ZIndex = 10
    particleContainer.Parent = frame
    particleContainer.Visible = false
    
    local particles = {}
    for i = 1, 50 do
        local particle = Instance.new("TextLabel")
        particle.Size = UDim2.new(0, 20, 0, 20)
        particle.BackgroundTransparency = 1
        particle.Text = math.random(0, 1)
        particle.TextColor3 = CurrentColor
        particle.TextSize = math.random(10, 20)
        particle.Font = Enum.Font.Code
        particle.Parent = particleContainer
        particle.ZIndex = 10
        particle.TextTransparency = 0.7
        particle.Rotation = math.random(-10, 10)
        table.insert(particles, particle)
    end
    return particleContainer, particles
end

-- Эффект распада на матричный код
local function matrixDissolveEffect(frame, callback)
    local container, particles = createMatrixParticles(frame)
    container.Visible = true
    
    local frameSize = frame.AbsoluteSize
    local framePos = frame.AbsolutePosition
    
    for i, particle in ipairs(particles) do
        particle.Position = UDim2.new(
            math.random(0, 100) / 100,
            math.random(-10, 10),
            math.random(0, 100) / 100,
            math.random(-10, 10)
        )
        
        -- Анимация разлета
        local targetPos = UDim2.new(
            math.random(-50, 150) / 100,
            math.random(-50, 50),
            math.random(-50, 150) / 100,
            math.random(-50, 50)
        )
        
        local tween = TweenService:Create(
            particle,
            TweenInfo.new(0.5, Enum.EasingStyle.Expo, Enum.EasingDirection.Out),
            {Position = targetPos, TextTransparency = 1, Rotation = math.random(-180, 180)}
        )
        tween:Play()
    end
    
    task.wait(0.5)
    container:Destroy()
    if callback then callback() end
end

-- Эффект сборки из матричного кода
local function matrixAssembleEffect(frame, callback)
    local container, particles = createMatrixParticles(frame)
    container.Visible = true
    
    -- Размещаем частицы по всему экрану
    for i, particle in ipairs(particles) do
        particle.Position = UDim2.new(
            math.random(-50, 150) / 100,
            math.random(-100, 100),
            math.random(-50, 150) / 100,
            math.random(-100, 100)
        )
        particle.TextTransparency = 0
    end
    
    -- Анимация сборки в центр
    task.wait(0.1)
    for i, particle in ipairs(particles) do
        local targetPos = UDim2.new(
            math.random(40, 60) / 100,
            math.random(-20, 20),
            math.random(40, 60) / 100,
            math.random(-20, 20)
        )
        
        local tween = TweenService:Create(
            particle,
            TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Position = targetPos, TextTransparency = 0.3, Rotation = 0}
        )
        tween:Play()
    end
    
    task.wait(0.3)
    container:Destroy()
    if callback then callback() end
end

-- Анимационные функции
local function animate(object, properties, duration, easingStyle, easingDirection)
    local tweenInfo = TweenInfo.new(duration or 0.2, easingStyle or Enum.EasingStyle.Quad, easingDirection or Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

-- Функция для создания неонового свечения
local function createGlow(parent, color, size)
    local glow = Instance.new("Frame")
    glow.Name = "Glow"
    glow.Size = UDim2.new(1, size or 4, 1, size or 4)
    glow.Position = UDim2.new(0, -(size or 2), 0, -(size or 2))
    glow.BackgroundColor3 = color or CurrentColor
    glow.BackgroundTransparency = 0.8
    glow.BorderSizePixel = 0
    glow.ZIndex = parent.ZIndex - 1
    glow.Parent = parent
    
    local blur = Instance.new("BlurEffect")
    blur.Size = 8
    blur.Parent = glow
    
    return glow
end


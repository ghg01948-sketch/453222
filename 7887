local function openPlayerInfo(player)
    playerInfoTitle.Text = "> " .. player.Name .. "_INFO.exe <"
    playerNameLabel.Text = "NAME: " .. player.Name
    playerIdLabel.Text = "USER_ID: " .. player.UserId
    
    local accountAge = "UNKNOWN"
    local joinDate = "UNKNOWN"
    
    local success, age = pcall(function()
        return player.AccountAge
    end)
    if success and age then
        accountAge = tostring(age) .. " DAYS"
    end
    
    local success2, joined = pcall(function()
        return os.date("%Y-%m-%d %H:%M:%S", player.AccountAge * 86400)
    end)
    if success2 and joined then
        joinDate = joined
    end
    
    accountAgeLabel.Text = "ACCOUNT_AGE: " .. accountAge
    joinDateLabel.Text = "JOINED: " .. joinDate
    
    -- Очистка leaderstats
    for _, child in ipairs(leaderstatsScroll:GetChildren()) do

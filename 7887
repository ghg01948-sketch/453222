            descLabel.TextSize = 9
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = buttonFrame
            
            local execSymbol = Instance.new("TextLabel")
            execSymbol.Size = UDim2.new(0, 20, 0, 20)
            execSymbol.Position = UDim2.new(1, -25, 0.5, -10)
            execSymbol.BackgroundTransparency = 1
            execSymbol.Text = "▶"
            execSymbol.TextColor3 = InactiveColor
            execSymbol.TextSize = 12
            execSymbol.Font = Enum.Font.Code
            execSymbol.Parent = buttonFrame
            
            local button = Instance.new("TextButton")
            button.Size = UDim2.new(1, 0, 1, 0)
            button.BackgroundTransparency = 1
            button.Text = ""
            button.Parent = buttonFrame
            
            button.MouseEnter:Connect(function()
                animate(buttonFrame, {BorderColor3 = CurrentColor}, 0.1)
                animate(execSymbol, {TextColor3 = CurrentColor}, 0.1)
            end)
            
            button.MouseLeave:Connect(function()
                animate(buttonFrame, {BorderColor3 = DarkBorderColor}, 0.1)
                animate(execSymbol, {TextColor3 = InactiveColor}, 0.1)
            end)
            
            button.MouseButton1Click:Connect(function()
                animate(buttonFrame, {BackgroundColor3 = Color3.fromRGB(10, 10, 10)}, 0.05)
                animate(execSymbol, {Text = "▶▶", TextColor3 = CurrentColor}, 0.05)
                wait(0.1)
                animate(buttonFrame, {BackgroundColor3 = Color3.fromRGB(0, 0, 0)}, 0.1)
                animate(execSymbol, {Text = "▶", TextColor3 = InactiveColor}, 0.1)
                
                if callback then
                    local success, err = pcall(callback)
                    if not success then
                        Library:Notification("ERROR", err, 2)
                    end
                end
            end)
            
            return SectionObject
        end
        
        function SectionObject:NewToggle(toggleName, description, callback)
            local toggleFrame = Instance.new("Frame")
            toggleFrame.Size = UDim2.new(1, 0, 0, 45)
            toggleFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            toggleFrame.BorderSizePixel = 1
            toggleFrame.BorderColor3 = DarkBorderColor
            toggleFrame.Parent = sectionContent
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -90, 0, 20)
            nameLabel.Position = UDim2.new(0, 5, 0, 3)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "> " .. toggleName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 12
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = toggleFrame
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -90, 0, 12)
            descLabel.Position = UDim2.new(0, 5, 0, 23)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = "  " .. (description or "toggle")
            descLabel.TextColor3 = InactiveColor
            descLabel.TextSize = 9
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = toggleFrame
            
            -- Новый хакерский переключатель в виде кода
            local toggleSwitch = Instance.new("Frame")
            toggleSwitch.Size = UDim2.new(0, 70, 0, 25)
            toggleSwitch.Position = UDim2.new(1, -75, 0.5, -12)
            toggleSwitch.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            toggleSwitch.BorderSizePixel = 1
            toggleSwitch.BorderColor3 = DarkBorderColor
            toggleSwitch.Parent = toggleFrame
            
            local binaryLabels = {}
            for i = 1, 3 do
                local binLabel = Instance.new("TextLabel")
                binLabel.Size = UDim2.new(0, 20, 1, 0)
                binLabel.Position = UDim2.new(0, (i-1) * 23 + 3, 0, 0)
                binLabel.BackgroundTransparency = 1
                binLabel.Text = i == 1 and "0" or (i == 2 and "1" or "0")
                binLabel.TextColor3 = InactiveColor
                binLabel.TextSize = 12
                binLabel.Font = Enum.Font.Code
                binLabel.Parent = toggleSwitch
                table.insert(binaryLabels, binLabel)
            end
            
            local toggleState = false
            
            local function updateToggle()
                if toggleState then
                    -- Включено: меняем бинарный код
                    for i, label in ipairs(binaryLabels) do
                        label.Text = i == 1 and "1" or (i == 2 and "1" or "1")
                        animate(label, {TextColor3 = CurrentColor}, 0.2)
                    end
                    animate(toggleSwitch, {BorderColor3 = CurrentColor}, 0.2)
                else
                    -- Выключено: возвращаем исходный код
                    for i, label in ipairs(binaryLabels) do
                        label.Text = i == 1 and "0" or (i == 2 and "1" or "0")
                        animate(label, {TextColor3 = InactiveColor}, 0.2)
                    end
                    animate(toggleSwitch, {BorderColor3 = DarkBorderColor}, 0.2)
                end
            end
            
            local toggleButton = Instance.new("TextButton")
            toggleButton.Size = UDim2.new(1, 0, 1, 0)
            toggleButton.BackgroundTransparency = 1
            toggleButton.Text = ""
            toggleButton.Parent = toggleFrame
            
            toggleButton.MouseButton1Click:Connect(function()
                toggleState = not toggleState
                updateToggle()
                
                if callback then
                    local success, err = pcall(function() callback(toggleState) end)
                    if not success then
                        Library:Notification("ERROR", "Toggle error", 2)
                    end
                end
            end)
            
            return SectionObject
        end
        
        function SectionObject:NewSlider(sliderName, description, min, max, default, callback)
            local sliderFrame = Instance.new("Frame")
            sliderFrame.Size = UDim2.new(1, 0, 0, 70)
            sliderFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            sliderFrame.BorderSizePixel = 1
            sliderFrame.BorderColor3 = DarkBorderColor
            sliderFrame.Parent = sectionContent
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -70, 0, 20)
            nameLabel.Position = UDim2.new(0, 5, 0, 3)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "> " .. sliderName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 12
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = sliderFrame
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -70, 0, 12)
            descLabel.Position = UDim2.new(0, 5, 0, 23)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = "  " .. (description or "adjust")
            descLabel.TextColor3 = InactiveColor
            descLabel.TextSize = 9
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = sliderFrame
            
            local valueLabel = Instance.new("TextLabel")
            valueLabel.Size = UDim2.new(0, 50, 0, 20)
            valueLabel.Position = UDim2.new(1, -55, 0, 5)
            valueLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            valueLabel.BorderSizePixel = 1
            valueLabel.BorderColor3 = CurrentColor
            valueLabel.Text = "[" .. tostring(default or min) .. "]"
            valueLabel.TextColor3 = CurrentColor
            valueLabel.TextSize = 10
            valueLabel.Font = Enum.Font.Code
            valueLabel.Parent = sliderFrame
            
            local sliderBg = Instance.new("Frame")
            sliderBg.Size = UDim2.new(1, -60, 0, 4)
            sliderBg.Position = UDim2.new(0, 5, 0, 50)
            sliderBg.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
            sliderBg.BorderSizePixel = 1
            sliderBg.BorderColor3 = DarkBorderColor
            sliderBg.Parent = sliderFrame
            
            local sliderFill = Instance.new("Frame")
            sliderFill.Size = UDim2.new(0, 0, 1, 0)
            sliderFill.BackgroundColor3 = CurrentColor
            sliderFill.BorderSizePixel = 0
            sliderFill.Parent = sliderBg
            
            -- Матричные полоски на слайдере
            for i = 1, 5 do
                local matrixLine = Instance.new("Frame")
                matrixLine.Size = UDim2.new(0, 1, 1, 0)
                matrixLine.Position = UDim2.new(0, i * 20, 0, 0)
                matrixLine.BackgroundColor3 = CurrentColor
                matrixLine.BackgroundTransparency = 0.7
                matrixLine.BorderSizePixel = 0
                matrixLine.Parent = sliderBg
            end
            
            local sliderButton = Instance.new("TextButton")
            sliderButton.Size = UDim2.new(1, 0, 1, 0)
            sliderButton.BackgroundTransparency = 1
            sliderButton.Text = ""
            sliderButton.Parent = sliderBg
            
            local currentValue = default or min
            local dragging = false
            
            local function updateSlider(input)
                local mousePos = input.Position
                local absPos = sliderBg.AbsolutePosition
                local absSize = sliderBg.AbsoluteSize.X
                
                local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                local percent = relativeX / absSize
                
                currentValue = math.floor(min + (max - min) * percent)
                currentValue = math.clamp(currentValue, min, max)
                
                sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                valueLabel.Text = "[" .. tostring(currentValue) .. "]"
                
                if callback then
                    local success, err = pcall(function() callback(currentValue) end)
                    if not success then
                        Library:Notification("ERROR", "Slider error", 2)
                    end
                end
            end
            
            if default then
                local percent = (default - min) / (max - min)
                sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                valueLabel.Text = "[" .. tostring(default) .. "]"
                if callback then pcall(function() callback(default) end) end
            end
            
            sliderButton.MouseButton1Down:Connect(function(input)
                dragging = true
                updateSlider(input)
                animate(sliderBg, {BorderColor3 = CurrentColor}, 0.1)
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input)
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                    animate(sliderBg, {BorderColor3 = DarkBorderColor}, 0.1)
                end
            end)
            
            return SectionObject
        end
        
        return SectionObject
    end
    
    return TabObject
end

function Library:Notification(title, message, duration)
    local notificationGui = Instance.new("ScreenGui")
    notificationGui.Name = "Notification"
    notificationGui.Parent = CoreGui
    notificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notificationGui.DisplayOrder = 200
    
    local notifFrame = Instance.new("Frame")
    notifFrame.Name = "NotificationFrame"
    notifFrame.Size = UDim2.new(0, 320, 0, 0)
    notifFrame.Position = UDim2.new(1, -340, 0, 20 + #Notifications * 80)
    notifFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    notifFrame.BorderSizePixel = 2
    notifFrame.BorderColor3 = DarkBorderColor
    notifFrame.Parent = notificationGui
    notifFrame.ClipsDescendants = true
    
    -- Матричный фон для уведомления
    local matrixBG = Instance.new("Frame")
    matrixBG.Size = UDim2.new(1, 0, 1, 0)
    matrixBG.BackgroundTransparency = 0.9
    matrixBG.BackgroundColor3 = CurrentColor
    matrixBG.Parent = notifFrame
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -30, 0, 25)
    titleLabel.Position = UDim2.new(0, 10, 0, 5)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = "[" .. title .. "]"
    titleLabel.TextColor3 = CurrentColor
    titleLabel.TextSize = 12
    titleLabel.Font = Enum.Font.Code
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notifFrame
    
    local messageLabel = Instance.new("TextLabel")
    messageLabel.Size = UDim2.new(1, -30, 0, 35)
    messageLabel.Position = UDim2.new(0, 10, 0, 30)
    messageLabel.BackgroundTransparency = 1
    messageLabel.Text = message
    messageLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    messageLabel.TextSize = 11
    messageLabel.Font = Enum.Font.Code
    messageLabel.TextWrapped = true
    messageLabel.TextXAlignment = Enum.TextXAlignment.Left
    messageLabel.Parent = notifFrame
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 25, 0, 25)
    closeBtn.Position = UDim2.new(1, -30, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    closeBtn.BorderSizePixel = 1
    closeBtn.BorderColor3 = CurrentColor
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = CurrentColor
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.Code
    closeBtn.Parent = notifFrame
    
    table.insert(Notifications, notifFrame)
    
    animate(notifFrame, {Size = UDim2.new(0, 320, 0, 75)}, 0.3)
    
    closeBtn.MouseButton1Click:Connect(function()
        for i, notif in ipairs(Notifications) do
            if notif == notifFrame then
                table.remove(Notifications, i)
                break
            end
        end
        
        animate(notifFrame, {Size = UDim2.new(0, 320, 0, 0), BackgroundTransparency = 1}, 0.2)
        task.wait(0.2)
        notificationGui:Destroy()
        
        for i, notif in ipairs(Notifications) do
            animate(notif, {Position = UDim2.new(1, -340, 0, 20 + (i - 1) * 80)}, 0.2)
        end
    end)
    
    if duration then
        task.wait(duration)
        if notificationGui and notificationGui.Parent then
            for i, notif in ipairs(Notifications) do
                if notif == notifFrame then
                    table.remove(Notifications, i)
                    break
                end
            end
            
            animate(notifFrame, {Size = UDim2.new(0, 320, 0, 0), BackgroundTransparency = 1}, 0.2)
            task.wait(0.2)
            notificationGui:Destroy()
            
            for i, notif in ipairs(Notifications) do
                animate(notif, {Position = UDim2.new(1, -340, 0, 20 + (i - 1) * 80)}, 0.2)
            end
        end
    end
end

return Library

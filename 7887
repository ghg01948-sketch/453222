    HideButton.Text = "◀"
    HideButton.TextColor3 = Colors.Accent
    HideButton.TextSize = 20
    HideButton.Font = Enum.Font.Code
    HideButton.Parent = titleBar
    
    local hideButtonCorner = Instance.new("UICorner")
    hideButtonCorner.CornerRadius = UDim.new(0, 6)
    hideButtonCorner.Parent = HideButton
    
    local titleText = Instance.new("TextLabel")
    titleText.Name = "TitleText"
    titleText.Size = UDim2.new(1, -100, 1, 0)
    titleText.Position = UDim2.new(0, 45, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title or "CODE B HACK MODULE // v8.0"
    titleText.TextColor3 = Colors.Text
    titleText.TextSize = 18
    titleText.Font = Enum.Font.Code
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Parent = titleBar
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name = "CloseButton"
    closeBtn.Size = UDim2.new(0, 35, 0, 35)
    closeBtn.Position = UDim2.new(1, -40, 0.5, -17.5)
    closeBtn.BackgroundColor3 = Colors.Background3
    closeBtn.BorderSizePixel = 0
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Colors.TextDim
    closeBtn.TextSize = 20
    closeBtn.Font = Enum.Font.Code
    closeBtn.Parent = titleBar
    
    local closeButtonCorner = Instance.new("UICorner")
    closeButtonCorner.CornerRadius = UDim.new(0, 6)
    closeButtonCorner.Parent = closeBtn
    
    closeBtn.MouseEnter:Connect(function()
        TweenService:Create(closeBtn, TweenInfo.new(0.2), {TextColor3 = Colors.Accent}):Play()
    end)
    
    closeBtn.MouseLeave:Connect(function()
        TweenService:Create(closeBtn, TweenInfo.new(0.2), {TextColor3 = Colors.TextDim}):Play()
    end)
    
    closeBtn.MouseButton1Click:Connect(function() 
        local fadeOut = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(GUI, fadeOut, {Enabled = false}):Play()
        task.wait(0.3)
        GUI:Destroy() 
    end)
    
    -- Resize Handle
    local ResizeButton = Instance.new("ImageButton")
    ResizeButton.Name = "ResizeButton"
    ResizeButton.Size = UDim2.new(0, 25, 0, 25)
    ResizeButton.Position = UDim2.new(1, -25, 1, -25)
    ResizeButton.BackgroundTransparency = 1
    ResizeButton.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
    ResizeButton.ImageColor3 = Colors.TextDim
    ResizeButton.Parent = MainFrame
    
    local arrowLabel = Instance.new("TextLabel")
    arrowLabel.Size = UDim2.new(1, 0, 1, 0)
    arrowLabel.BackgroundTransparency = 1
    arrowLabel.Text = "↘"
    arrowLabel.TextColor3 = Colors.TextDim
    arrowLabel.TextSize = 18
    arrowLabel.Font = Enum.Font.Code
    arrowLabel.Parent = ResizeButton
    
    -- Основной контент
    ColumnsFrame = Instance.new("Frame")
    ColumnsFrame.Name = "ColumnsFrame"
    ColumnsFrame.Size = UDim2.new(1, -20, 1, -110)
    ColumnsFrame.Position = UDim2.new(0, 10, 0, 55)
    ColumnsFrame.BackgroundTransparency = 1
    ColumnsFrame.Parent = MainFrame
    
    -- Tab Bar
    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.Size = UDim2.new(1, -20, 0, 45)
    tabBar.Position = UDim2.new(0, 10, 0, 5)
    tabBar.BackgroundColor3 = Colors.Background2
    tabBar.BorderSizePixel = 0
    tabBar.Parent = MainFrame
    
    local tabBarCorner = Instance.new("UICorner")
    tabBarCorner.CornerRadius = UDim.new(0, 8)
    tabBarCorner.Parent = tabBar
    
    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -10, 1, -10)
    tabContainer.Position = UDim2.new(0, 5, 0, 5)
    tabContainer.BackgroundTransparency = 1
    tabContainer.Parent = tabBar
    
    -- Bottom Info Bar
    local bottomFrame = Instance.new("Frame")
    bottomFrame.Name = "BottomFrame"
    bottomFrame.Size = UDim2.new(1, -20, 0, 40)
    bottomFrame.Position = UDim2.new(0, 10, 1, -45)
    bottomFrame.BackgroundColor3 = Colors.Background2
    bottomFrame.BorderSizePixel = 0
    bottomFrame.Parent = MainFrame
    
    local bottomCorner = Instance.new("UICorner")
    bottomCorner.CornerRadius = UDim.new(0, 8)
    bottomCorner.Parent = bottomFrame
    
    local versionText = Instance.new("TextLabel")
    versionText.Size = UDim2.new(1, -10, 1, 0)
    versionText.Position = UDim2.new(0, 5, 0, 0)
    versionText.BackgroundTransparency = 1
    versionText.Text = "[ SYSTEM: ONLINE // STATUS: ACTIVE ]"
    versionText.TextColor3 = Colors.TextDim
    versionText.TextSize = 11
    versionText.Font = Enum.Font.Code
    versionText.TextXAlignment = Enum.TextXAlignment.Left
    versionText.Parent = bottomFrame
    
    local statusIndicator = Instance.new("Frame")
    statusIndicator.Name = "StatusIndicator"
    statusIndicator.Size = UDim2.new(0, 8, 0, 8)
    statusIndicator.Position = UDim2.new(1, -15, 0.5, -4)
    statusIndicator.BackgroundColor3 = Colors.Accent
    statusIndicator.BorderSizePixel = 0
    statusIndicator.Parent = bottomFrame
    
    local statusCorner = Instance.new("UICorner")
    statusCorner.CornerRadius = UDim.new(1, 0)
    statusCorner.Parent = statusIndicator
    
    -- Анимация индикатора
    RunService.Heartbeat:Connect(function()
        local pulse = (math.sin(os.clock() * 5) + 1) / 2
        statusIndicator.BackgroundTransparency = 0.3 + (pulse * 0.3)
    end)
    
    -- Drag System
    local dragging = false
    local dragInput, dragStart, startPos
    
    local function updateDrag(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
    
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            updateDrag(input)
        end
    end)
    
    -- Resize System
    local resizing = false
    local resizeInput, resizeStart, startSize
    
    local function updateResize(input)
        local delta = input.Position - resizeStart
        local newWidth = math.max(400, startSize.X.Offset + delta.X)
        local newHeight = math.max(500, startSize.Y.Offset + delta.Y)
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        ExpandedSize = UDim2.new(0, newWidth, 0, newHeight)
    end
    
    ResizeButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resizeStart = input.Position
            startSize = MainFrame.Size
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    resizing = false
                end
            end)
        end
    end)
    
    ResizeButton.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            resizeInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == resizeInput and resizing then
            updateResize(input)
        end
    end)
    
    -- Hide/Show Animation
    HideButton.MouseButton1Click:Connect(function()
        IsVisible = not IsVisible
        local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        if IsVisible then
            HideButton.Text = "◀"
            TweenService:Create(MainFrame, tweenInfo, {Size = ExpandedSize}):Play()
            TweenService:Create(HideButton, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Background3}):Play()
            
            -- Fade in content
            for _, v in pairs({ColumnsFrame, tabBar, bottomFrame, ResizeButton}) do
                TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
            end
        else
            HideButton.Text = "▶"
            TweenService:Create(MainFrame, tweenInfo, {Size = MinimizedSize}):Play()
            TweenService:Create(HideButton, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent}):Play()
            
            -- Fade out content
            for _, v in pairs({ColumnsFrame, tabBar, bottomFrame, ResizeButton}) do
                TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            end
        end
    end)
    
    -- Hotkey
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.RightControl then
            IsVisible = not IsVisible
            local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            
            if IsVisible then
                HideButton.Text = "◀"
                TweenService:Create(MainFrame, tweenInfo, {Size = ExpandedSize}):Play()
                TweenService:Create(HideButton, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Background3}):Play()
                
                for _, v in pairs({ColumnsFrame, tabBar, bottomFrame, ResizeButton}) do
                    v.Visible = true
                    TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
                end
            else
                HideButton.Text = "▶"
                TweenService:Create(MainFrame, tweenInfo, {Size = MinimizedSize}):Play()
                TweenService:Create(HideButton, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent}):Play()
                
                for _, v in pairs({ColumnsFrame, tabBar, bottomFrame, ResizeButton}) do
                    TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                    task.wait(0.2)
                    v.Visible = false
                end
            end
        end
    end)
    
    -- Tab sizing function
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end
        
        local tabWidth = math.floor((containerWidth - 5 * (tabCount - 1)) / tabCount)
        tabWidth = math.clamp(tabWidth, 80, 150)
        
        for i, tabBtn in ipairs(TabButtons) do
            TweenService:Create(tabBtn, TweenInfo.new(0.2), {
                Size = UDim2.new(0, tabWidth, 1, -2),
                Position = UDim2.new(0, (i - 1) * (tabWidth + 5) + 5, 0, 1)
            }):Play()
        end
    end
    
    tabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
    
    return self
end


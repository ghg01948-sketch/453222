end

local function updateGamesList()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local places = filterPlaces("")
    
    for i, placeData in ipairs(places) do
        local gameButton = createGameButton(placeData, i)
        gameButton.Parent = scrollFrame
    end
    
    headerText.Text = "> PLACES: " .. #places .. "/" .. #allPlaces .. " <"
end

local function loadPlaces()
    if isLoading then return end
    
    isLoading = true
    headerText.Text = "> LOADING_PLACES... <"
    
    task.spawn(function()
        local success, places = pcall(function()
            return getUniversePlaces()
        end)
        
        if success and places then
            allPlaces = places
            updateGamesList()
        else
            headerText.Text = "> FAILED_TO_LOAD_PLACES <"
            table.insert(allPlaces, {
                PlaceId = game.PlaceId,
                Name = "Current Place"
            })
            updateGamesList()
        end
        
        isLoading = false
    end)
end

local function animateIcon(isOpening)
    local tweenService = game:GetService("TweenService")
    
    if isOpening then
        tweenService:Create(lines[1], TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.2, 0, 0.45, 0),
            Rotation = 45,
            Size = UDim2.new(0.6, 0, 0, 2)
        }):Play()
        
        tweenService:Create(lines[2], TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 1
        }):Play()
        
        tweenService:Create(lines[3], TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.2, 0, 0.45, 0),
            Rotation = -45,
            Size = UDim2.new(0.6, 0, 0, 2)
        }):Play()
    else
        tweenService:Create(lines[1], TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0.15, 0),
            Rotation = 0,
            Size = UDim2.new(1, 0, 0, 2)
        }):Play()
        
        tweenService:Create(lines[2], TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0,
            Position = UDim2.new(0, 0, 0.5, 0)
        }):Play()
        
        tweenService:Create(lines[3], TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0.85, 0),
            Rotation = 0,
            Size = UDim2.new(1, 0, 0, 2)
        }):Play()
    end
end

local function toggleMenu()
    local tweenService = game:GetService("TweenService")
    
    if isMenuOpen then
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tween = tweenService:Create(menuFrame, tweenInfo, {
            Size = UDim2.new(0, 0, 0, 0)
        })
        
        tween.Completed:Connect(function()
            menuFrame.Visible = false
            deleteButton.Visible = false
        end)
        
        tween:Play()
        animateIcon(false)
        isMenuOpen = false
        
    else
        menuWidth, menuHeight = getMenuDimensions()
        menuFrame.Visible = true
        
        local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        tweenService:Create(menuFrame, tweenInfo, {
            Size = UDim2.new(0, menuWidth, 0, menuHeight)
        }):Play()
        
        animateIcon(true)
        
        task.spawn(function()
            task.wait(0.2)
            deleteButton.Visible = true
            loadPlaces()
            updatePlayersList()
        end)
        
        isMenuOpen = true
    end
end

local function deleteMenu()
    if isMenuOpen then
        toggleMenu()
    end
    
    menuButton:Destroy()
end

deleteButton.MouseEnter:Connect(function()
    local tweenService = game:GetService("TweenService")
    tweenService:Create(deleteButton, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    }):Play()
end)

deleteButton.MouseLeave:Connect(function()
    local tweenService = game:GetService("TweenService")
    tweenService:Create(deleteButton, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(20, 0, 0)
    }):Play()
end)

deleteButton.MouseButton1Click:Connect(function()

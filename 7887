            local contentY = 0
            local dropdownFrame
            local dropdownContent
            
            -- Создаем основной контейнер дропдауна
            dropdownFrame = Instance.new("Frame")
            dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
            dropdownFrame.Position = UDim2.new(0, 0, 0, currentY)

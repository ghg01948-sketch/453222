                button.MouseLeave:Connect(function()
                    TweenService:Create(buttonFrame, TweenInfo.new(0.2), {
                        BackgroundColor3 = Color3.fromRGB(12, 12, 12),
                        BorderColor3 = Color3.fromRGB(60, 60, 60)
                    }):Play()
                    TweenService:Create(nameLabel, TweenInfo.new(0.2), {
                        TextColor3 = Color3.fromRGB(180, 180, 180)
                    }):Play()
                end)
                
                button.MouseButton1Click:Connect(function()
                    TweenService:Create(buttonFrame, TweenInfo.new(0.1), {
                        BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                    }):Play()
                    task.wait(0.1)
                    TweenService:Create(buttonFrame, TweenInfo.new(0.1), {
                        BackgroundColor3 = Color3.fromRGB(12, 12, 12)
                    }):Play()
                    
                    if buttonCallback then
                        local success, err = pcall(buttonCallback)
                        if not success then warn("Error in dropdown button callback: " .. err) end
                    end
                end)
                
                contentY = contentY + 50
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    updateDropdownPosition()
                end
            end
            
            function DropdownObject:NewToggle(toggleName, description, callback)
                local btnY = contentY
                
                local toggleFrame = Instance.new("Frame")
                toggleFrame.Size = UDim2.new(1, -20, 0, 55)
                toggleFrame.Position = UDim2.new(0, 10, 0, btnY)
                toggleFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
                toggleFrame.BorderSizePixel = 1
                toggleFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                toggleFrame.Parent = dropdownContent
                toggleFrame.ZIndex = 108
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -80, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = "  " .. toggleName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = toggleFrame
                nameLabel.ZIndex = 109
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -80, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = "    " .. (description or "")
                descLabel.TextColor3 = Color3.fromRGB(120, 120, 120)
                descLabel.TextSize = 11
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = toggleFrame
                descLabel.ZIndex = 109
                
                local toggleBg = Instance.new("Frame")
                toggleBg.Size = UDim2.new(0, 50, 0, 24)
                toggleBg.Position = UDim2.new(1, -60, 0.5, -12)
                toggleBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                toggleBg.BorderSizePixel = 2
                toggleBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                toggleBg.Parent = toggleFrame
                toggleBg.ZIndex = 109
                
                local toggleIndicator = Instance.new("Frame")
                toggleIndicator.Size = UDim2.new(0, 20, 0, 16)
                toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                toggleIndicator.BorderSizePixel = 1
                toggleIndicator.BorderColor3 = Color3.fromRGB(140, 140, 140)
                toggleIndicator.Parent = toggleBg
                toggleIndicator.ZIndex = 110
                
                local toggleState = false
                
                local function updateToggle()
                    if toggleState then
                        TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {
                            BackgroundColor3 = CurrentColor,
                            Position = UDim2.new(1, -22, 0.5, -8)
                        }):Play()
                    else
                        TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {
                            BackgroundColor3 = Color3.fromRGB(100, 100, 100),
                            Position = UDim2.new(0, 2, 0.5, -8)
                        }):Play()
                    end
                end
                
                local toggleButton = Instance.new("TextButton")
                toggleButton.Size = UDim2.new(1, 0, 1, 0)
                toggleButton.BackgroundTransparency = 1
                toggleButton.Text = ""
                toggleButton.Parent = toggleFrame
                toggleButton.ZIndex = 110
                
                toggleButton.MouseButton1Click:Connect(function()
                    toggleState = not toggleState
                    updateToggle()
                    
                    if callback then
                        local success, err = pcall(function() callback(toggleState) end)
                        if not success then warn("Error in dropdown toggle callback: " .. err) end
                    end
                end)
                
                contentY = contentY + 60
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    updateDropdownPosition()
                end
            end
            
            function DropdownObject:NewSlider(sliderName, description, min, max, default, callback)
                local btnY = contentY
                
                local sliderFrame = Instance.new("Frame")
                sliderFrame.Size = UDim2.new(1, -20, 0, 70)
                sliderFrame.Position = UDim2.new(0, 10, 0, btnY)
                sliderFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
                sliderFrame.BorderSizePixel = 1
                sliderFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                sliderFrame.Parent = dropdownContent
                sliderFrame.ZIndex = 108
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = "  " .. sliderName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = sliderFrame
                nameLabel.ZIndex = 109
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -20, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = "    " .. (description or "")
                descLabel.TextColor3 = Color3.fromRGB(120, 120, 120)
                descLabel.TextSize = 11
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = sliderFrame
                descLabel.ZIndex = 109
                
                local valueLabel = Instance.new("TextLabel")
                valueLabel.Size = UDim2.new(0, 50, 0, 20)
                valueLabel.Position = UDim2.new(1, -60, 0, 30)
                valueLabel.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                valueLabel.BorderSizePixel = 1
                valueLabel.BorderColor3 = Color3.fromRGB(80, 80, 80)
                valueLabel.Text = tostring(default or min)
                valueLabel.TextColor3 = CurrentColor
                valueLabel.TextSize = 11
                valueLabel.Font = Enum.Font.Code
                valueLabel.Parent = sliderFrame
                valueLabel.ZIndex = 109
                
                local sliderBg = Instance.new("Frame")
                sliderBg.Size = UDim2.new(1, -80, 0, 8)
                sliderBg.Position = UDim2.new(0, 10, 0, 52)
                sliderBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                sliderBg.BorderSizePixel = 1
                sliderBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                sliderBg.Parent = sliderFrame
                sliderBg.ZIndex = 109
                
                local sliderFill = Instance.new("Frame")
                sliderFill.Size = UDim2.new(0, 0, 1, 0)
                sliderFill.BackgroundColor3 = CurrentColor
                sliderFill.BorderSizePixel = 0
                sliderFill.Parent = sliderBg
                sliderFill.ZIndex = 110
                
                local sliderButton = Instance.new("TextButton")
                sliderButton.Size = UDim2.new(1, 0, 1, 0)
                sliderButton.BackgroundTransparency = 1
                sliderButton.Text = ""
                sliderButton.Parent = sliderBg
                sliderButton.ZIndex = 110
                
                local currentValue = default or min
                local dragging = false
                
                local function updateSlider(input)
                    local mousePos = input.Position
                    local absPos = sliderBg.AbsolutePosition
                    local absSize = sliderBg.AbsoluteSize.X
                    
                    local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                    local percent = relativeX / absSize
                    
                    currentValue = math.floor(min + (max - min) * percent)
                    currentValue = math.clamp(currentValue, min, max)
                    
                    TweenService:Create(sliderFill, TweenInfo.new(0.1), {
                        Size = UDim2.new(percent, 0, 1, 0)
                    }):Play()
                    valueLabel.Text = tostring(currentValue)
                    
                    if callback then
                        local success, err = pcall(function() callback(currentValue) end)
                        if not success then warn("Error in dropdown slider callback: " .. err) end
                    end
                end
                
                if default then
                    local percent = (default - min) / (max - min)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(default)
                    if callback then pcall(function() callback(default) end) end
                end
                
                sliderButton.MouseButton1Down:Connect(function(input)
                    dragging = true
                    updateSlider(input)
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                contentY = contentY + 75
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    updateDropdownPosition()
                end
            end
            
            return DropdownObject
        end
        

    HideButton = Instance.new("TextButton")
    HideButton.Name = "HideButton"
    HideButton.Size = UDim2.new(0, 35, 0, 35)
    HideButton.Position = UDim2.new(0, 5, 0.5, -17.5)
    HideButton.BackgroundColor3 = Colors.Background3

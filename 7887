    -- Системные мониторы обновление
    local lastTime = tick()
    local frameCount = 0
    local networkUsage = 0
    local lastNetworkStats = 0

    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
        local currentTime = tick()
        
        if currentTime - lastTime >= 1 then
            SystemData.FPS = frameCount
            frameCount = 0
            lastTime = currentTime
            
            -- Memory
            local mem = Stats:GetTotalMemoryUsageMb()
            SystemData.Memory = math.floor(mem * 10) / 10
            
            -- Ping
            local ping = Stats.Network.ServerStatsItem:GetValue("DataPing") or 0
            SystemData.Ping = math.floor(ping)
            
            -- Players
            SystemData.Players = #Players:GetPlayers()
            
            -- Network
            local networkIn = Stats.Network.ServerStatsItem:GetValue("DataReceiveKbps") or 0
            SystemData.Network = math.floor(networkIn)
            
            -- Обновление мониторов
            fpsMonitor.Text = tostring(SystemData.FPS)
            pingMonitor.Text = tostring(SystemData.Ping) .. "ms"
            memMonitor.Text = tostring(SystemData.Memory) .. "MB"
            plyMonitor.Text = tostring(SystemData.Players)
            netMonitor.Text = tostring(SystemData.Network) .. "KB"
        end
    end)

    -- Функция обновления размеров табов
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end

        local tabWidth = math.floor((containerWidth - 5 * (tabCount - 1)) / tabCount)
        tabWidth = math.clamp(tabWidth, 70, 120)

        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, -2)
            tabBtn.Position = UDim2.new(0, (i - 1) * (tabWidth + 5) + 5, 0, 1)
        end
    end

    tabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)

    return self
end

-- ===== КЛАСС TAB =====
function Library:NewTab(name)
    local tabContainer = ColumnsFrame:FindFirstChild("TabContainer")
    if not tabContainer then
        tabContainer = Instance.new("Frame")
        tabContainer.Name = "TabContainer"
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.Parent = ColumnsFrame
    end

    -- ScrollingFrame для вкладки
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.Position = UDim2.new(0, 0, 0, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel = 0
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 4
    tabFrame.ScrollBarImageColor3 = Color3.fromRGB(50, 50, 60)
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false

    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame

    -- Создаем кнопку вкладки
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")

    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -2)
        tabButton.Position = UDim2.new(0, (#TabButtons * 105 + 5), 0, 1)
        tabButton.BackgroundColor3 = (#TabButtons == 0) and Color3.fromRGB(20, 20, 25) or Color3.fromRGB(12, 12, 15)
        tabButton.Text = name
        tabButton.TextColor3 = (#TabButtons == 0) and CurrentColor or Color3.fromRGB(140, 140, 140)
        tabButton.TextSize = 12
        tabButton.Font = Enum.Font.SourceSansBold
        tabButton.BorderSizePixel = 0
        tabButton.Parent = tabButtonContainer

        table.insert(TabButtons, tabButton)

        if #TabButtons == 1 then
            tabFrame.Visible = true
            local indicator = Instance.new("Frame")
            indicator.Size = UDim2.new(1, 0, 0, 2)
            indicator.Position = UDim2.new(0, 0, 1, -2)
            indicator.BackgroundColor3 = CurrentColor
            indicator.BorderSizePixel = 0
            indicator.Parent = tabButton
        end

        tabButton.MouseButton1Click:Connect(function()
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end

            tabFrame.Visible = true

            for _, btn in ipairs(TabButtons) do
                btn.BackgroundColor3 = Color3.fromRGB(12, 12, 15)
                btn.TextColor3 = Color3.fromRGB(140, 140, 140)
                for _, child in pairs(btn:GetChildren()) do
                    if child:IsA("Frame") then
                        child:Destroy()
                    end
                end
            end

            tabButton.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
            tabButton.TextColor3 = CurrentColor

            local indicator = Instance.new("Frame")
            indicator.Size = UDim2.new(1, 0, 0, 2)
            indicator.Position = UDim2.new(0, 0, 1, -2)
            indicator.BackgroundColor3 = CurrentColor
            indicator.BorderSizePixel = 0
            indicator.Parent = tabButton
        end)

        local function updateTabSizes()
            local containerWidth = tabButtonContainer.AbsoluteSize.X
            local tabCount = #TabButtons
            if tabCount == 0 then return end

            local tabWidth = math.floor((containerWidth - 5 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 70, 120)

            for i, btn in ipairs(TabButtons) do
                btn.Size = UDim2.new(0, tabWidth, 1, -2)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 5) + 5, 0, 1)
            end
        end

        tabButtonContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
        updateTabSizes()
    end


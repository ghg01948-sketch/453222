        end
    end
end)

local function getMenuDimensions()
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local height = math.min(viewportSize.X, viewportSize.Y) * 0.75
    local width = viewportSize.X * 0.75
    return width, height
end


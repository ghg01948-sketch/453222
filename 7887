-- Функция для создания новой вкладки (без изменений)
function Library:NewTab(name)
    -- ... (код функции) ...
    local TabObject = {}
    function TabObject:NewSection(sectionName)
        local SectionObject = {}
        -- ... (код создания секции) ...

        -- (Все существующие методы: NewButton, NewToggle, NewSlider, NewTextBlock остаются без изменений)
        
        -- ========== ОБНОВЛЕННЫЙ МЕТОД NewDropdown ==========
        function SectionObject:NewDropdown(dropdownName, description)
            local DropdownObject = {}
            local currentY = tabData.YPosition
            local isOpen = false
            local contentY = 0
            local dropdownFrame
            local dropdownContent
            
            -- Создаем основной контейнер дропдауна
            dropdownFrame = Instance.new("Frame")
            dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
            dropdownFrame.Position = UDim2.new(0, 0, 0, currentY)
            dropdownFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            dropdownFrame.BorderSizePixel = 2
            dropdownFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            dropdownFrame.Parent = container
            dropdownFrame.ClipsDescendants = true
            
            -- Кнопка заголовка дропдауна
            local dropdownButton = Instance.new("TextButton")
            dropdownButton.Size = UDim2.new(1, 0, 0, 50)
            dropdownButton.Position = UDim2.new(0, 0, 0, 0)
            dropdownButton.BackgroundTransparency = 1
            dropdownButton.Text = ""
            dropdownButton.Parent = dropdownFrame
            
            -- Название дропдауна
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -50, 0, 25)
            nameLabel.Position = UDim2.new(0, 10, 0, 5)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = dropdownName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 16
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = dropdownFrame
            
            -- Описание
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -50, 0, 20)
            descLabel.Position = UDim2.new(0, 10, 0, 25)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = description or ""
            descLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
            descLabel.TextSize = 12
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = dropdownFrame
            
            -- Стрелочка
            local arrowLabel = Instance.new("TextLabel")
            arrowLabel.Size = UDim2.new(0, 30, 0, 30)
            arrowLabel.Position = UDim2.new(1, -40, 0, 10)
            arrowLabel.BackgroundTransparency = 1
            arrowLabel.Text = "▼"
            arrowLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
            arrowLabel.TextSize = 20
            arrowLabel.Font = Enum.Font.Code
            arrowLabel.Parent = dropdownFrame
            
            -- Контейнер для элементов внутри дропдауна
            dropdownContent = Instance.new("Frame")
            dropdownContent.Name = "DropdownContent"
            dropdownContent.Size = UDim2.new(1, 0, 0, 0)
            dropdownContent.Position = UDim2.new(0, 0, 0, 50)
            dropdownContent.BackgroundTransparency = 1
            dropdownContent.Parent = dropdownFrame
            dropdownContent.Visible = false
            
            -- Функция для обновления всех позиций элементов в секции
            local function updateAllPositions()
                local startY = 40 -- Начинаем после заголовка секции
                for _, child in ipairs(container:GetChildren()) do
                    if child:IsA("Frame") and child ~= sectionTitle and child ~= sectionLine then
                        child.Position = UDim2.new(0, 0, 0, startY)
                        startY = startY + child.Size.Y.Offset + 10
                    end
                end
                tabData.YPosition = startY
                tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, startY + 10)
            end
            
            -- Функция открытия/закрытия
            local function toggleDropdown()
                isOpen = not isOpen
                
                if isOpen then
                    arrowLabel.Text = "▲"
                    dropdownContent.Visible = true
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50 + contentY)
                else
                    arrowLabel.Text = "▼"
                    dropdownContent.Visible = false
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
                end
                
                -- Обновляем позиции всех элементов
                updateAllPositions()
            end
            
            dropdownButton.MouseButton1Click:Connect(toggleDropdown)
            
            -- ========== НОВЫЕ МЕТОДЫ ВНУТРИ DROPDOWN ==========
            
            -- Кнопка внутри Dropdown
            function DropdownObject:NewButton(buttonName, buttonCallback)
                local btnY = contentY
                
                local buttonFrame = Instance.new("Frame")
                buttonFrame.Size = UDim2.new(1, -20, 0, 40)
                buttonFrame.Position = UDim2.new(0, 10, 0, btnY)
                buttonFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                buttonFrame.BorderSizePixel = 1
                buttonFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                buttonFrame.Parent = dropdownContent
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = buttonName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = buttonFrame
                
                local button = Instance.new("TextButton")
                button.Size = UDim2.new(1, 0, 1, 0)
                button.BackgroundTransparency = 1
                button.Text = ""
                button.Parent = buttonFrame
                
                button.MouseEnter:Connect(function()
                    buttonFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                end)
                
                button.MouseLeave:Connect(function()
                    buttonFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                end)
                
                button.MouseButton1Click:Connect(function()
                    buttonFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                    task.wait(0.1)
                    buttonFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                    
                    if buttonCallback then
                        local success, err = pcall(buttonCallback)
                        if not success then
                            warn("Error in dropdown button callback: " .. err)
                        end
                    end
                end)
                
                contentY = contentY + 45
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50 + contentY)
                end
                
                updateAllPositions()
            end

            -- Тумблер внутри Dropdown
            function DropdownObject:NewToggle(toggleName, description, callback)
                local btnY = contentY
                local toggleId = tostring(math.random(10000, 99999))
                
                local toggleFrame = Instance.new("Frame")
                toggleFrame.Size = UDim2.new(1, -20, 0, 50)
                toggleFrame.Position = UDim2.new(0, 10, 0, btnY)
                toggleFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                toggleFrame.BorderSizePixel = 1
                toggleFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                toggleFrame.Parent = dropdownContent
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -80, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = toggleName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = toggleFrame
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -80, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = description or ""
                descLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
                descLabel.TextSize = 12
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = toggleFrame
                
                -- Рычаг
                local toggleBg = Instance.new("Frame")
                toggleBg.Size = UDim2.new(0, 50, 0, 24)
                toggleBg.Position = UDim2.new(1, -60, 0.5, -12)
                toggleBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                toggleBg.BorderSizePixel = 2
                toggleBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                toggleBg.Parent = toggleFrame
                
                local toggleIndicator = Instance.new("Frame")
                toggleIndicator.Size = UDim2.new(0, 20, 0, 16)
                toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                toggleIndicator.BorderSizePixel = 1
                toggleIndicator.BorderColor3 = Color3.fromRGB(140, 140, 140)
                toggleIndicator.Parent = toggleBg
                
                local toggleState = false
                ToggleStates[toggleId] = false
                
                local function updateToggle()
                    if toggleState then
                        toggleIndicator.BackgroundColor3 = CurrentColor
                        toggleIndicator.Position = UDim2.new(1, -22, 0.5, -8)
                    else
                        toggleIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                        toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                    end
                end
                
                local toggleButton = Instance.new("TextButton")
                toggleButton.Size = UDim2.new(1, 0, 1, 0)
                toggleButton.BackgroundTransparency = 1
                toggleButton.Text = ""
                toggleButton.Parent = toggleFrame
                
                toggleButton.MouseButton1Click:Connect(function()
                    toggleState = not toggleState
                    ToggleStates[toggleId] = toggleState
                    updateToggle()
                    
                    if callback then
                        local success, err = pcall(function()
                            callback(toggleState)
                        end)
                        if not success then
                            warn("Error in dropdown toggle callback: " .. err)
                        end
                    end
                end)
                
                function DropdownObject:GetToggleState()
                    return toggleState
                end
                
                contentY = contentY + 55
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50 + contentY)
                end
                
                updateAllPositions()
            end

            -- Ползунок внутри Dropdown
            function DropdownObject:NewSlider(sliderName, description, min, max, default, callback)
                local btnY = contentY
                local sliderId = tostring(math.random(10000, 99999))
                
                local sliderFrame = Instance.new("Frame")
                sliderFrame.Size = UDim2.new(1, -20, 0, 70)
                sliderFrame.Position = UDim2.new(0, 10, 0, btnY)
                sliderFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                sliderFrame.BorderSizePixel = 1
                sliderFrame.BorderColor3 = Color3.fromRGB(60, 60, 60)
                sliderFrame.Parent = dropdownContent
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -20, 0, 25)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = sliderName
                nameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Code
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = sliderFrame
                
                local descLabel = Instance.new("TextLabel")
                descLabel.Size = UDim2.new(1, -20, 0, 20)
                descLabel.Position = UDim2.new(0, 10, 0, 25)
                descLabel.BackgroundTransparency = 1
                descLabel.Text = description or ""
                descLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
                descLabel.TextSize = 12
                descLabel.Font = Enum.Font.Code
                descLabel.TextXAlignment = Enum.TextXAlignment.Left
                descLabel.Parent = sliderFrame
                
                -- Значение ползунка
                local valueLabel = Instance.new("TextLabel")
                valueLabel.Size = UDim2.new(0, 50, 0, 20)
                valueLabel.Position = UDim2.new(1, -60, 0, 28)
                valueLabel.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                valueLabel.BorderSizePixel = 1
                valueLabel.BorderColor3 = Color3.fromRGB(80, 80, 80)
                valueLabel.Text = tostring(default or min)
                valueLabel.TextColor3 = CurrentColor
                valueLabel.TextSize = 12
                valueLabel.Font = Enum.Font.Code
                valueLabel.Parent = sliderFrame
                
                -- Полоса ползунка
                local sliderBg = Instance.new("Frame")
                sliderBg.Size = UDim2.new(1, -80, 0, 10)
                sliderBg.Position = UDim2.new(0, 10, 0, 50)
                sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                sliderBg.BorderSizePixel = 1
                sliderBg.BorderColor3 = Color3.fromRGB(80, 80, 80)
                sliderBg.Parent = sliderFrame
                
                local sliderFill = Instance.new("Frame")
                sliderFill.Size = UDim2.new(0, 0, 1, 0)
                sliderFill.BackgroundColor3 = CurrentColor
                sliderFill.BorderSizePixel = 0
                sliderFill.Parent = sliderBg
                
                local sliderButton = Instance.new("TextButton")
                sliderButton.Size = UDim2.new(1, 0, 1, 0)
                sliderButton.BackgroundTransparency = 1
                sliderButton.Text = ""
                sliderButton.Parent = sliderBg
                
                local currentValue = default or min
                local dragging = false
                
                local function updateSlider(input)
                    local mousePos = input.Position
                    local absPos = sliderBg.AbsolutePosition
                    local absSize = sliderBg.AbsoluteSize.X
                    
                    local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                    local percent = relativeX / absSize
                    
                    currentValue = math.floor(min + (max - min) * percent)
                    if currentValue < min then currentValue = min end
                    if currentValue > max then currentValue = max end
                    
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(currentValue)
                    SliderValues[sliderId] = currentValue
                    
                    if callback then
                        local success, err = pcall(function()
                            callback(currentValue)
                        end)
                        if not success then
                            warn("Error in dropdown slider callback: " .. err)
                        end
                    end
                end
                
                if default then
                    local percent = (default - min) / (max - min)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(default)
                    SliderValues[sliderId] = default
                    
                    if callback then
                        pcall(function()
                            callback(default)
                        end)
                    end
                end
                
                sliderButton.MouseButton1Down:Connect(function(input)
                    dragging = true
                    updateSlider(input)
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                function DropdownObject:GetSliderValue()
                    return currentValue
                end
                
                contentY = contentY + 75
                dropdownContent.Size = UDim2.new(1, 0, 0, contentY)
                
                if isOpen then
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50 + contentY)
                end
                
                updateAllPositions()
            end
            
            tabData.YPosition = currentY + 50
            tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, tabData.YPosition + 10)
            
            return DropdownObject
        end
        
        -- (Метод NewTextBlock без изменений)
        
        return SectionObject
    end
    return TabObject
end

function Library:GetToggleState(id)
    return ToggleStates[id] or false
end

function Library:GetSliderValue(id)
    return SliderValues[id] or 0
end

return Library

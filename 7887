-- Функция для создания новой вкладки
function Library:NewTab(name)
    TabCounter = TabCounter + 1
    local tabContainer = UIElements.TabContainer
    local tabCount = #TabButtons
    
    -- Создаем кнопку вкладки
    local tabButton = Instance.new("TextButton")
    tabButton.Name = "Tab_" .. name .. "_" .. TabCounter
    tabButton.Size = UDim2.new(0, 100, 1, -2)
    tabButton.Position = UDim2.new(0, tabCount * 105 + 5, 0, 1)
    tabButton.BackgroundTransparency = 1
    tabButton.Text = name
    tabButton.TextColor3 = (tabCount == 0) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 140)
    tabButton.TextSize = 14
    tabButton.Font = Enum.Font.Code
    tabButton.BorderSizePixel = 0
    tabButton.Parent = tabContainer
    
    table.insert(TabButtons, tabButton)
    
    -- Создаем контейнер для этой вкладки
    local section = Instance.new("ScrollingFrame")
    section.Name = name .. "Section_" .. TabCounter
    section.Size = UDim2.new(1, 0, 1, 0)
    section.Position = UDim2.new(0, 0, 0, 0)
    section.BackgroundTransparency = 1
    section.BorderSizePixel = 0
    section.CanvasSize = UDim2.new(0, 0, 0, 0)
    section.ScrollBarThickness = 8
    section.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
    section.Parent = ColumnsFrame
    section.Visible = (tabCount == 0)
    
    local container = Instance.new("Frame")
    container.Name = "Container_" .. TabCounter
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = section
    
    local tabData = {
        Frame = section,
        Container = container,
        YPosition = 0,
        Button = tabButton,
        Name = name,
        Index = TabCounter
    }
    
    local tabKey = name .. "_" .. TabCounter
    Sections[tabKey] = tabData
    Tabs[tabKey] = tabData
    
    -- Если это первая вкладка, делаем её активной
    if tabCount == 0 then
        CurrentTab = tabKey
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 2)
        line.Position = UDim2.new(0, 0, 1, -2)
        line.BackgroundColor3 = CurrentColor
        line.BorderSizePixel = 0
        line.Parent = tabButton
        UIElements.ActiveLine = line
    end
    
    -- Обработчик нажатия на вкладку
    tabButton.MouseButton1Click:Connect(function()
        CurrentTab = tabKey
        
        for _, btn in ipairs(TabButtons) do
            btn.TextColor3 = Color3.fromRGB(140, 140, 140)
        end
        tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        if UIElements.ActiveLine then
            UIElements.ActiveLine:Destroy()
        end
        
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 2)
        line.Position = UDim2.new(0, 0, 1, -2)
        line.BackgroundColor3 = CurrentColor
        line.BorderSizePixel = 0
        line.Parent = tabButton
        UIElements.ActiveLine = line
        
        for _, tab in pairs(Sections) do
            tab.Frame.Visible = false
        end
        tabData.Frame.Visible = true
    end)
    
    -- Обновляем размеры вкладок
    if UIElements.updateTabSizes then
        UIElements.updateTabSizes()
    end
    
    -- Создаем объект вкладки с методами
    local TabObject = {}
    
    function TabObject:NewSection(sectionName)
        local SectionObject = {}
        local container = tabData.Container
        local yPos = tabData.YPosition
        
        -- Заголовок секции
        local sectionTitle = Instance.new("TextLabel")
        sectionTitle.Size = UDim2.new(1, 0, 0, 30)
        sectionTitle.Position = UDim2.new(0, 0, 0, yPos)
        sectionTitle.BackgroundTransparency = 1
        sectionTitle.Text = "// " .. sectionName
        sectionTitle.TextColor3 = Color3.fromRGB(230, 230, 230)
        sectionTitle.TextSize = 16
        sectionTitle.Font = Enum.Font.Code
        sectionTitle.TextXAlignment = Enum.TextXAlignment.Left
        sectionTitle.Parent = container
        
        -- Линия под заголовком
        local sectionLine = Instance.new("Frame")
        sectionLine.Size = UDim2.new(1, 0, 0, 2)
        sectionLine.Position = UDim2.new(0, 0, 0, yPos + 25)
        sectionLine.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        sectionLine.BorderSizePixel = 0
        sectionLine.Parent = container
        
        tabData.YPosition = yPos + 40
        
        -- Функция для обновления всех позиций
        local function updateAllPositions()
            local startY = 40
            for _, child in ipairs(container:GetChildren()) do
                if child:IsA("Frame") and child ~= sectionTitle and child ~= sectionLine then
                    child.Position = UDim2.new(0, 0, 0, startY)
                    startY = startY + child.Size.Y.Offset + 10
                end
            end
            tabData.YPosition = startY
            tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, startY + 10)
        end
        

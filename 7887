            local tabWidth = math.floor((containerWidth - 5 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 70, 120)
            
            for i, btn in ipairs(TabButtons) do
                btn.Size = UDim2.new(0, tabWidth, 1, -2)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 5) + 5, 0, 1)

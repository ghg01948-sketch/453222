    container.Parent = tabFrame
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local containerLayout = Instance.new("UIListLayout")
    containerLayout.Padding = UDim.new(0, 15)
    containerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    containerLayout.Parent = container
    
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -10)
        tabButton.Position = UDim2.new(0, (#TabButtons * 110 + 5), 0, 5)
        tabButton.BackgroundColor3 = (#TabButtons == 0) and Color3.fromRGB(30, 30, 36) or Color3.fromRGB(22, 22, 28)
        tabButton.BorderSizePixel = 0
        tabButton.Text = ""
        tabButton.Parent = tabButtonContainer
        tabButton.AutoButtonColor = false
        
        local tabButtonCorner = Instance.new("UICorner")
        tabButtonCorner.CornerRadius = UDim.new(0, 8)
        tabButtonCorner.Parent = tabButton
        
        local tabText = Instance.new("TextLabel")
        tabText.Size = UDim2.new(1, 0, 1, 0)
        tabText.BackgroundTransparency = 1
        tabText.Text = name
        tabText.TextColor3 = (#TabButtons == 0) and CurrentColor or Color3.fromRGB(140, 140, 150)
        tabText.TextSize = 14
        tabText.Font = Enum.Font.GothamSemibold
        tabText.Parent = tabButton
        
        table.insert(TabButtons, tabButton)
        
        if #TabButtons == 1 then
            tabFrame.Visible = true
        end
        
        tabButton.MouseButton1Click:Connect(function()
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            tabFrame.Visible = true
            animate(tabFrame, {BackgroundTransparency = 0}, 0.3)
            
            for _, btn in ipairs(TabButtons) do
                animate(btn, {BackgroundColor3 = Color3.fromRGB(22, 22, 28)}, 0.2)
                local text = btn:FindFirstChildOfClass("TextLabel")
                if text then
                    animate(text, {TextColor3 = Color3.fromRGB(140, 140, 150)}, 0.2)
                end
            end
            
            animate(tabButton, {BackgroundColor3 = Color3.fromRGB(30, 30, 36)}, 0.2)
            animate(tabText, {TextColor3 = CurrentColor}, 0.2)
        end)
        
        tabButton.MouseEnter:Connect(function()
            if tabText.TextColor3 ~= CurrentColor then
                animate(tabButton, {BackgroundColor3 = Color3.fromRGB(28, 28, 34)}, 0.2)
                animate(tabText, {TextColor3 = Color3.fromRGB(180, 180, 190)}, 0.2)
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if tabText.TextColor3 ~= CurrentColor then
                animate(tabButton, {BackgroundColor3 = Color3.fromRGB(22, 22, 28)}, 0.2)
                animate(tabText, {TextColor3 = Color3.fromRGB(140, 140, 150)}, 0.2)
            end
        end)
        
        tabButtonContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
            local containerWidth = tabButtonContainer.AbsoluteSize.X
            local tabCount = #TabButtons
            if tabCount == 0 then return end
            
            local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 80, 150)
            
            for i, btn in ipairs(TabButtons) do
                animate(btn, {Size = UDim2.new(0, tabWidth, 1, -10)}, 0.2)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 5)
            end
        end)
    end
    

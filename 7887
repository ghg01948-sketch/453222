    logoText.TextColor3 = CurrentColor
    logoText.TextSize = 16
    logoText.Font = Enum.Font.GothamBold
    logoText.TextXAlignment = Enum.TextXAlignment.Left
    logoText.Parent = topBar

    -- Статус система
    local statusText = Instance.new("TextLabel")
    statusText.Name = "StatusText"
    statusText.Size = UDim2.new(0, 120, 1, 0)
    statusText.Position = UDim2.new(0, 170, 0, 0)
    statusText.BackgroundTransparency = 1
    statusText.Text = "[ SYSTEM: ACTIVE ]"
    statusText.TextColor3 = Color3.fromRGB(0, 255, 100)
    statusText.TextSize = 12
    statusText.Font = Enum.Font.Gotham
    statusText.TextXAlignment = Enum.TextXAlignment.Left
    statusText.Parent = topBar

    -- Кнопки управления окном
    local function createWindowButton(symbol, color, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 30, 0, 30)
        btn.Position = UDim2.new(1, -(35 + (#callback or 0)*35), 0, 0)
        btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        btn.Text = symbol
        btn.TextColor3 = color or Color3.fromRGB(255, 255, 255)
        btn.TextSize = 14
        btn.Font = Enum.Font.Gotham
        btn.BorderSizePixel = 0
        btn.Parent = topBar
        
        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        end)
        
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        end)
        
        return btn
    end

    local closeBtn = createWindowButton("✕", Color3.fromRGB(255, 80, 80))
    closeBtn.Position = UDim2.new(1, -35, 0, 0)
    closeBtn.MouseButton1Click:Connect(function() GUI:Destroy() end)

    local minimizeBtn = createWindowButton("—", Color3.fromRGB(255, 255, 255))
    minimizeBtn.Position = UDim2.new(1, -70, 0, 0)
    minimizeBtn.MouseButton1Click:Connect(function()
        IsVisible = false
        MainFrame:TweenSize(UDim2.new(0, 300, 0, 30), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
        ColumnsFrame.Visible = false
    end)

    HideButton = createWindowButton("◀", CurrentColor)
    HideButton.Position = UDim2.new(1, -105, 0, 0)
    HideButton.MouseButton1Click:Connect(function()
        IsVisible = not IsVisible
        if IsVisible then
            HideButton.Text = "◀"
            MainFrame:TweenSize(UDim2.new(0, 700, 0, 500), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
            ColumnsFrame.Visible = true
        else
            HideButton.Text = "▶"
            MainFrame:TweenSize(UDim2.new(0, 300, 0, 30), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
            ColumnsFrame.Visible = false
        end
    end)

    -- Навигационная панель (вкладки)
    local navBar = Instance.new("Frame")
    navBar.Name = "NavBar"
    navBar.Size = UDim2.new(1, 0, 0, 40)
    navBar.Position = UDim2.new(0, 0, 0, 30)
    navBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    navBar.BorderSizePixel = 0
    navBar.Parent = MainFrame

    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -20, 1, 0)
    tabContainer.Position = UDim2.new(0, 10, 0, 0)
    tabContainer.BackgroundTransparency = 1
    tabContainer.Parent = navBar

    -- Основной контент
    ColumnsFrame = Instance.new("Frame")
    ColumnsFrame.Name = "ColumnsFrame"
    ColumnsFrame.Size = UDim2.new(1, 0, 1, -100)
    ColumnsFrame.Position = UDim2.new(0, 0, 0, 70)
    ColumnsFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    ColumnsFrame.BorderSizePixel = 0
    ColumnsFrame.Parent = MainFrame

    -- Нижняя панель (статус бар)
    local bottomBar = Instance.new("Frame")
    bottomBar.Name = "BottomBar"
    bottomBar.Size = UDim2.new(1, 0, 0, 30)
    bottomBar.Position = UDim2.new(0, 0, 1, -30)
    bottomBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    bottomBar.BorderSizePixel = 0
    bottomBar.Parent = MainFrame

    -- Системная информация в нижней панели
    local versionInfo = Instance.new("TextLabel")
    versionInfo.Size = UDim2.new(0, 200, 1, 0)
    versionInfo.Position = UDim2.new(0, 10, 0, 0)
    versionInfo.BackgroundTransparency = 1
    versionInfo.Text = "ZIVCAS OS " .. SystemData.Version
    versionInfo.TextColor3 = Color3.fromRGB(150, 150, 150)
    versionInfo.TextSize = 12
    versionInfo.Font = Enum.Font.Gotham
    versionInfo.TextXAlignment = Enum.TextXAlignment.Left
    versionInfo.Parent = bottomBar

    -- Мониторы в нижней панели
    local monitors = {}
    local monitorNames = {"FPS", "PING", "MEM", "PLAYERS"}
    local monitorValues = {"60", "0ms", "0MB", "1"}
    local monitorWidth = 70

    for i, name in ipairs(monitorNames) do
        local container = Instance.new("Frame")
        container.Size = UDim2.new(0, monitorWidth, 1, 0)
        container.Position = UDim2.new(1, -(monitorWidth * (#monitorNames - i + 1) + 10), 0, 0)
        container.BackgroundTransparency = 1
        container.Parent = bottomBar

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 30, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = name .. ":"
        label.TextColor3 = Color3.fromRGB(150, 150, 150)
        label.TextSize = 11
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = container

        local value = Instance.new("TextLabel")
        value.Name = "Value"
        value.Size = UDim2.new(0, 35, 1, 0)
        value.Position = UDim2.new(0, 35, 0, 0)
        value.BackgroundTransparency = 1
        value.Text = monitorValues[i]
        value.TextColor3 = CurrentColor
        value.TextSize = 11
        value.Font = Enum.Font.GothamBold
        value.TextXAlignment = Enum.TextXAlignment.Right
        value.Parent = container

        monitors[name] = value
    end

    -- Drag handling
    local dragging = false
    local dragStart, startPos

    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Hotkey (RightControl)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.RightControl then
            IsVisible = not IsVisible
            if IsVisible then
                HideButton.Text = "◀"
                MainFrame:TweenSize(UDim2.new(0, 700, 0, 500), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
                ColumnsFrame.Visible = true
            else
                HideButton.Text = "▶"
                MainFrame:TweenSize(UDim2.new(0, 300, 0, 30), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
                ColumnsFrame.Visible = false
            end
        end
    end)

    -- System monitors update
    local lastTime = tick()
    local frameCount = 0

    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
        local currentTime = tick()
        
        if currentTime - lastTime >= 1 then
            SystemData.FPS = frameCount
            frameCount = 0
            lastTime = currentTime
            
            SystemData.Memory = math.floor(Stats:GetTotalMemoryUsageMb() * 10) / 10
            SystemData.Ping = math.floor(Stats.Network.ServerStatsItem:GetValue("DataPing") or 0)
            SystemData.Players = #Players:GetPlayers()
            
            monitors["FPS"].Text = tostring(SystemData.FPS)
            monitors["PING"].Text = tostring(SystemData.Ping) .. "ms"
            monitors["MEM"].Text = tostring(SystemData.Memory) .. "MB"
            monitors["PLAYERS"].Text = tostring(SystemData.Players)
        end
    end)

    -- Tab size update function
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end

        local tabWidth = math.floor(containerWidth / tabCount)

        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, 0)
            tabBtn.Position = UDim2.new(0, (i - 1) * tabWidth, 0, 0)
        end
    end

    navBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)

    return self
end

-- Tab Class
function Library:NewTab(name)
    local tabContainer = ColumnsFrame:FindFirstChild("TabContainer")
    if not tabContainer then
        tabContainer = Instance.new("Frame")
        tabContainer.Name = "TabContainer"
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.Parent = ColumnsFrame
    end

    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.Position = UDim2.new(0, 0, 0, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel = 0
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 4
    tabFrame.ScrollBarImageColor3 = CurrentColor
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false

    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -30, 1, -30)
    container.Position = UDim2.new(0, 15, 0, 15)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame

    -- Create tab button
    local navBar = MainFrame:FindFirstChild("NavBar")
    local tabButtonContainer = navBar and navBar:FindFirstChild("TabContainer")

    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, 0)
        tabButton.BackgroundColor3 = (#TabButtons == 0) and Color3.fromRGB(20, 20, 20) or Color3.fromRGB(0, 0, 0)
        tabButton.Text = "  " .. name
        tabButton.TextColor3 = (#TabButtons == 0) and CurrentColor or Color3.fromRGB(150, 150, 150)
        tabButton.TextSize = 13
        tabButton.Font = Enum.Font.GothamBold
        tabButton.BorderSizePixel = 0
        tabButton.TextXAlignment = Enum.TextXAlignment.Left
        tabButton.Parent = tabButtonContainer

        table.insert(TabButtons, tabButton)

        if #TabButtons == 1 then
            tabFrame.Visible = true
        end

        tabButton.MouseButton1Click:Connect(function()
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end

            tabFrame.Visible = true

            for _, btn in ipairs(TabButtons) do
                btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                btn.TextColor3 = Color3.fromRGB(150, 150, 150)
            end

            tabButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            tabButton.TextColor3 = CurrentColor
        end)

        updateTabSizes()
    end

    local TabObject = {}
    local elementY = 0

    function TabObject:NewSection(sectionName)

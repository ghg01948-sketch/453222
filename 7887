-- Анимационные функции
local function animate(object, properties, duration, easingStyle, easingDirection)
    local tweenInfo = TweenInfo.new(duration or 0.2, easingStyle or Enum.EasingStyle.Quad, easingDirection or Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

-- Функция создания хакерского текста
local function hackerText(text)
    local result = ""
    for i = 1, #text do
        local char = text:sub(i, i)
        if char == " " then
            result = result .. " "
        else
            result = result .. string.char(math.random(65, 90))
        end
    end
    return result
end

-- Эффект печатной машинки
local function typewriterEffect(label, text, speed)
    speed = speed or 0.05
    label.Text = ""
    spawn(function()
        for i = 1, #text do
            label.Text = label.Text .. text:sub(i, i)
            wait(speed)
        end
    end)
end

-- Функция создания ASCII рамки
local function createAsciiBorder(parent, size)
    local border = Instance.new("Frame")
    border.Size = size
    border.BackgroundTransparency = 1
    border.Parent = parent
    
    local corners = {
        {"┌", UDim2.new(0, 2, 0, 2)},
        {"┐", UDim2.new(1, -12, 0, 2)},
        {"└", UDim2.new(0, 2, 1, -12)},
        {"┘", UDim2.new(1, -12, 1, -12)}
    }
    
    for _, corner in ipairs(corners) do
        local cornerLabel = Instance.new("TextLabel")
        cornerLabel.Size = UDim2.new(0, 10, 0, 10)
        cornerLabel.Position = corner[2]
        cornerLabel.BackgroundTransparency = 1
        cornerLabel.Text = corner[1]
        cornerLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        cornerLabel.TextSize = 14
        cornerLabel.Font = Enum.Font.Code
        cornerLabel.Parent = border
    end
    

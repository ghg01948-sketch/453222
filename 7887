-- Создание эффекта размытия
local function createBlur()
    local blur = Instance.new("BlurEffect")
    blur.Name = "MenuBlur"
    blur.Size = 0
    blur.Parent = game:GetService("Lighting")
    return blur
end

-- Функция создания неонового свечения
local function createNeonGlow(parent, color, size, transparency)
    local glow = Instance.new("ImageLabel")
    glow.Name = "NeonGlow"
    glow.Size = size or UDim2.new(1, 20, 1, 20)
    glow.Position = UDim2.new(0, -10, 0, -10)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://5028857643"
    glow.ImageColor3 = color or Colors.Accent
    glow.ImageTransparency = transparency or 0.7
    glow.Parent = parent
    return glow
end

-- Функция создания градиента
local function createGradient(parent, colors, rotation)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new(colors)
    gradient.Rotation = rotation or 0
    gradient.Parent = parent
    return gradient
end

-- Функция создания скругленных углов
local function addCorners(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = parent
    return corner
end

-- Функция создания тени
local function createShadow(parent, size, transparency)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.Size = size or UDim2.new(1, 30, 1, 30)
    shadow.Position = UDim2.new(0, -15, 0, -15)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://5028857643"
    shadow.ImageColor3 = Colors.Shadow
    shadow.ImageTransparency = transparency or 0.8
    shadow.Parent = parent
    return shadow
end

-- Функция создания разделителя
local function createDivider(parent, color, thickness, margin)
    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(1, -(margin * 2 or 20), 0, thickness or 1)
    divider.Position = UDim2.new(0, margin or 10, 1, -(margin or 10))
    divider.BackgroundColor3 = color or Colors.Border
    divider.BorderSizePixel = 0
    divider.Parent = parent
    return divider
end


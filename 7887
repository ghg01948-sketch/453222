                if isOpen then
                    arrowLabel.Text = "▲"
                    dropdownContent.Visible = true
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50 + contentY)
                else
                    arrowLabel.Text = "▼"
                    dropdownContent.Visible = false
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 50)
                end
                
                updateAllPositions()
            end
            
            dropdownButton.MouseButton1Click:Connect(toggleDropdown)
            
            -- Сохраняем ссылки для внутренних методов
            local dropdownRef = {
                frame = dropdownFrame,
                content = dropdownContent,
                contentY = contentY,
                isOpen = isOpen,
                updateAll = updateAllPositions
            }
            

    tabFrame.Visible = false
    
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = tabFrame
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)
    
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 0, 0)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local containerLayout = Instance.new("UIListLayout")
    containerLayout.Padding = UDim.new(0, 10)
    containerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    containerLayout.Parent = container
    
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -4)
        tabButton.Position = UDim2.new(0, (#TabButtons * 110 + 5), 0, 2)
        tabButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tabButton.BorderSizePixel = 1
        tabButton.BorderColor3 = (#TabButtons == 0) and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(40, 40, 40)
        tabButton.Text = ">_" .. name
        tabButton.TextColor3 = (#TabButtons == 0) and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(100, 100, 100)
        tabButton.TextSize = 12
        tabButton.Font = Enum.Font.Code
        tabButton.Parent = tabButtonContainer
        
        table.insert(TabButtons, tabButton)
        
        if #TabButtons == 1 then
            tabFrame.Visible = true
        end
        
        tabButton.MouseButton1Click:Connect(function()
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            tabFrame.Visible = true
            
            for _, btn in ipairs(TabButtons) do
                btn.BorderColor3 = Color3.fromRGB(40, 40, 40)
                btn.TextColor3 = Color3.fromRGB(100, 100, 100)
            end
            
            tabButton.BorderColor3 = Color3.fromRGB(0, 255, 0)
            tabButton.TextColor3 = Color3.fromRGB(0, 255, 0)
            
            -- Анимация клика
            animate(tabButton, {TextTransparency = 0.5}, 0.1)
            wait(0.1)
            animate(tabButton, {TextTransparency = 0}, 0.1)
        end)
        
        tabButton.MouseEnter:Connect(function()
            if tabButton.TextColor3 ~= Color3.fromRGB(0, 255, 0) then
                animate(tabButton, {TextColor3 = Color3.fromRGB(150, 255, 150)}, 0.2)
                animate(tabButton, {BorderColor3 = Color3.fromRGB(100, 255, 100)}, 0.2)
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if tabButton.TextColor3 ~= Color3.fromRGB(0, 255, 0) then
                animate(tabButton, {TextColor3 = Color3.fromRGB(100, 100, 100)}, 0.2)
                animate(tabButton, {BorderColor3 = Color3.fromRGB(40, 40, 40)}, 0.2)
            end
        end)
        
        tabButtonContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
            local containerWidth = tabButtonContainer.AbsoluteSize.X
            local tabCount = #TabButtons
            if tabCount == 0 then return end
            
            local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 70, 150)
            
            for i, btn in ipairs(TabButtons) do
                btn.Size = UDim2.new(0, tabWidth, 1, -4)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 2)
            end
        end)
    end
    

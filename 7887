-- Анимационные функции
local function animate(object, properties, duration, easingStyle, easingDirection)
    local tweenInfo = TweenInfo.new(duration or 0.2, easingStyle or Enum.EasingStyle.Quad, easingDirection or Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

-- Функция для создания полосы изменения размера
local function createResizeHandles(frame)
    -- Правая сторона
    local rightHandle = Instance.new("Frame")
    rightHandle.Name = "RightResizeHandle"
    rightHandle.Size = UDim2.new(0, 5, 1, -10)
    rightHandle.Position = UDim2.new(1, -5, 0, 5)
    rightHandle.BackgroundColor3 = CurrentColor
    rightHandle.BackgroundTransparency = 0.8
    rightHandle.BorderSizePixel = 0
    rightHandle.Parent = frame
    rightHandle.Visible = true
    
    -- Нижняя сторона
    local bottomHandle = Instance.new("Frame")
    bottomHandle.Name = "BottomResizeHandle"
    bottomHandle.Size = UDim2.new(1, -10, 0, 5)
    bottomHandle.Position = UDim2.new(0, 5, 1, -5)
    bottomHandle.BackgroundColor3 = CurrentColor
    bottomHandle.BackgroundTransparency = 0.8
    bottomHandle.BorderSizePixel = 0
    bottomHandle.Parent = frame
    bottomHandle.Visible = true
    
    -- Угол (правый нижний)
    local cornerHandle = Instance.new("Frame")
    cornerHandle.Name = "CornerResizeHandle"
    cornerHandle.Size = UDim2.new(0, 10, 0, 10)
    cornerHandle.Position = UDim2.new(1, -10, 1, -10)
    cornerHandle.BackgroundColor3 = CurrentColor
    cornerHandle.BackgroundTransparency = 0.5
    cornerHandle.BorderSizePixel = 0
    cornerHandle.Parent = frame
    cornerHandle.Visible = true
    
    -- Добавляем иконку в угол
    local cornerIcon = Instance.new("TextLabel")
    cornerIcon.Size = UDim2.new(1, 0, 1, 0)
    cornerIcon.BackgroundTransparency = 1
    cornerIcon.Text = "◢"
    cornerIcon.TextColor3 = CurrentColor
    cornerIcon.TextSize = 8
    cornerIcon.Font = Enum.Font.Code
    cornerIcon.Parent = cornerHandle
    
    -- Функции для ресайза
    local function startResize(direction)
        return function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                Resizing = true
                ResizeDirection = direction
                
                -- Подсветка при ресайзе
                rightHandle.BackgroundTransparency = 0.3
                bottomHandle.BackgroundTransparency = 0.3
                cornerHandle.BackgroundTransparency = 0.3
            end
        end
    end
    
    local function resize(input)
        if not Resizing or not ResizeDirection then return end
        
        local mousePos = input.Position
        local framePos = frame.AbsolutePosition
        local frameSize = frame.AbsoluteSize
        local newSize = frameSize
        
        if ResizeDirection == "right" or ResizeDirection == "corner" then
            newSize = Vector2.new(
                math.clamp(mousePos.X - framePos.X, MinSize.X, MaxSize.X),
                frameSize.Y
            )
        end
        
        if ResizeDirection == "bottom" or ResizeDirection == "corner" then
            newSize = Vector2.new(
                frameSize.X,
                math.clamp(mousePos.Y - framePos.Y, MinSize.Y, MaxSize.Y)
            )
        end
        
        if ResizeDirection == "corner" then
            newSize = Vector2.new(
                math.clamp(mousePos.X - framePos.X, MinSize.X, MaxSize.X),
                math.clamp(mousePos.Y - framePos.Y, MinSize.Y, MaxSize.Y)
            )
        end
        
        frame.Size = UDim2.new(0, newSize.X, 0, newSize.Y)
        
        -- Обновляем позицию ColumnsFrame при ресайзе
        if ColumnsFrame then
            ColumnsFrame.Size = UDim2.new(1, -20, 1, -150)
        end
    end
    
    local function endResize()
        Resizing = false
        ResizeDirection = nil
        rightHandle.BackgroundTransparency = 0.8
        bottomHandle.BackgroundTransparency = 0.8
        cornerHandle.BackgroundTransparency = 0.5
    end
    
    -- Подключаем события
    rightHandle.InputBegan:Connect(startResize("right"))
    bottomHandle.InputBegan:Connect(startResize("bottom"))
    cornerHandle.InputBegan:Connect(startResize("corner"))
    
    UserInputService.InputChanged:Connect(function(input)
        if Resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            resize(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            endResize()
        end
    end)
    
    -- Hover эффекты
    local function onHandleHover(handle, transparency)
        return function()
            if not Resizing then
                animate(handle, {BackgroundTransparency = transparency}, 0.1)
            end
        end
    end
    
    rightHandle.MouseEnter:Connect(onHandleHover(rightHandle, 0.5))
    rightHandle.MouseLeave:Connect(onHandleHover(rightHandle, 0.8))
    bottomHandle.MouseEnter:Connect(onHandleHover(bottomHandle, 0.5))
    bottomHandle.MouseLeave:Connect(onHandleHover(bottomHandle, 0.8))
    cornerHandle.MouseEnter:Connect(onHandleHover(cornerHandle, 0.2))
    cornerHandle.MouseLeave:Connect(onHandleHover(cornerHandle, 0.5))
end


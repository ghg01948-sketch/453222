        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            titleBar.BorderColor3 = CurrentColor
        end
    end)
    
    -- Функционал для перемещения элементов внутри секций
    local function makeElementDraggable(element, elementType, section)
        local dragHandle = Instance.new("Frame")
        dragHandle.Name = "DragHandle"
        dragHandle.Size = UDim2.new(0, 20, 1, 0)
        dragHandle.Position = UDim2.new(0, 0, 0, 0)
        dragHandle.BackgroundColor3 = CurrentColor
        dragHandle.BackgroundTransparency = 0.9
        dragHandle.BorderSizePixel = 0
        dragHandle.Parent = element
        dragHandle.ZIndex = 10
        
        local dragIcon = Instance.new("TextLabel")
        dragIcon.Size = UDim2.new(1, 0, 1, 0)
        dragIcon.BackgroundTransparency = 1
        dragIcon.Text = "⋮⋮"
        dragIcon.TextColor3 = CurrentColor
        dragIcon.TextSize = 12
        dragIcon.Font = Enum.Font.Code
        dragIcon.Parent = dragHandle
        dragIcon.ZIndex = 11
        
        local dragging = false
        local startY, elementPos
        
        dragHandle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                startY = input.Position.Y
                elementPos = element.Position
                animate(dragHandle, {BackgroundTransparency = 0.5}, 0.1)
                element.ZIndex = 100
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local deltaY = input.Position.Y - startY
                local newPos = UDim2.new(0, elementPos.X.Offset, 0, elementPos.Y.Offset + deltaY)
                
                -- Ограничиваем перемещение в пределах секции
                if section then
                    local sectionSize = section.AbsoluteSize.Y
                    local elementHeight = element.AbsoluteSize.Y
                    newPos = UDim2.new(0, elementPos.X.Offset, 0, math.clamp(elementPos.Y.Offset + deltaY, 0, sectionSize - elementHeight))
                end
                
                element.Position = newPos
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
                dragging = false
                animate(dragHandle, {BackgroundTransparency = 0.9}, 0.1)
                element.ZIndex = 1
            end
        end)
        
        dragHandle.MouseEnter:Connect(function()
            if not dragging then
                animate(dragHandle, {BackgroundTransparency = 0.7}, 0.1)
            end
        end)
        
        dragHandle.MouseLeave:Connect(function()
            if not dragging then
                animate(dragHandle, {BackgroundTransparency = 0.9}, 0.1)
            end
        end)
    end
    
    -- Сохраняем функцию для использования в секциях
    Library.MakeElementDraggable = makeElementDraggable
    
    -- Hide/show functionality
    HideButton.MouseButton1Click:Connect(function()
        IsVisible = not IsVisible
        
        if IsVisible then
            HideButton.Text = "◀"
            animate(MainFrame, {Size = UDim2.new(0, 600, 0, 650)}, 0.3)
            wait(0.1)
            ColumnsFrame.Visible = true
            tabBar.Visible = true
            bottomFrame.Visible = true
            statusBar.Visible = true
        else
            HideButton.Text = "▶"
            animate(MainFrame, {Size = UDim2.new(0, 200, 0, 35)}, 0.3)
            ColumnsFrame.Visible = false
            tabBar.Visible = false
            bottomFrame.Visible = false
            statusBar.Visible = false
        end
    end)
    
    -- Hotkey
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed then
            if input.KeyCode == Enum.KeyCode.RightControl then
                IsVisible = not IsVisible
                
                if IsVisible then
                    HideButton.Text = "◀"
                    animate(MainFrame, {Size = UDim2.new(0, 600, 0, 650)}, 0.3)
                    wait(0.1)
                    ColumnsFrame.Visible = true
                    tabBar.Visible = true
                    bottomFrame.Visible = true
                    statusBar.Visible = true
                else
                    HideButton.Text = "▶"
                    animate(MainFrame, {Size = UDim2.new(0, 200, 0, 35)}, 0.3)
                    ColumnsFrame.Visible = false
                    tabBar.Visible = false
                    bottomFrame.Visible = false
                    statusBar.Visible = false
                end
            elseif input.KeyCode == Enum.KeyCode.Escape then
                GUI:Destroy()
            end
        end
    end)
    
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end
        
        local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
        tabWidth = math.clamp(tabWidth, 70, 150)
        
        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, -4)
            tabBtn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 2)
        end
    end
    
    tabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
    
    return self
end

function Library:NewTab(name)
    local tabContainer = ColumnsFrame:FindFirstChild("TabContainer")
    if not tabContainer then
        tabContainer = Instance.new("Frame")
        tabContainer.Name = "TabContainer"
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.Parent = ColumnsFrame
    end
    
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.Position = UDim2.new(0, 0, 0, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel = 0
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 4
    tabFrame.ScrollBarImageColor3 = CurrentColor
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false
    
    -- Layout для автоматического расположения
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 10)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = tabFrame
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)
    
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 0, 0)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local containerLayout = Instance.new("UIListLayout")
    containerLayout.Padding = UDim.new(0, 10)
    containerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    containerLayout.Parent = container
    
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -4)
        tabButton.Position = UDim2.new(0, (#TabButtons * 110 + 5), 0, 2)
        tabButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tabButton.BorderSizePixel = 1
        tabButton.BorderColor3 = (#TabButtons == 0) and CurrentColor or InactiveColor
        tabButton.Text = name
        tabButton.TextColor3 = (#TabButtons == 0) and CurrentColor or InactiveColor
        tabButton.TextSize = 12
        tabButton.Font = Enum.Font.Code
        tabButton.Parent = tabButtonContainer
        
        table.insert(TabButtons, tabButton)
        
        if #TabButtons == 1 then
            tabFrame.Visible = true
        end
        
        tabButton.MouseButton1Click:Connect(function()
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            tabFrame.Visible = true
            
            for _, btn in ipairs(TabButtons) do
                btn.BorderColor3 = InactiveColor
                btn.TextColor3 = InactiveColor
            end
            
            tabButton.BorderColor3 = CurrentColor
            tabButton.TextColor3 = CurrentColor
        end)
        
        tabButton.MouseEnter:Connect(function()
            if tabButton.TextColor3 ~= CurrentColor then
                animate(tabButton, {TextColor3 = Color3.fromRGB(200, 200, 200)}, 0.2)
                animate(tabButton, {BorderColor3 = Color3.fromRGB(200, 200, 200)}, 0.2)
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if tabButton.TextColor3 ~= CurrentColor then
                animate(tabButton, {TextColor3 = InactiveColor}, 0.2)
                animate(tabButton, {BorderColor3 = InactiveColor}, 0.2)
            end
        end)
        
        tabButtonContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
            local containerWidth = tabButtonContainer.AbsoluteSize.X
            local tabCount = #TabButtons
            if tabCount == 0 then return end
            
            local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 70, 150)
            
            for i, btn in ipairs(TabButtons) do
                btn.Size = UDim2.new(0, tabWidth, 1, -4)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 2)
            end
        end)
    end
    

end)

local clickHandler
clickHandler = UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and isMenuOpen then
        local mouse = UserInputService:GetMouseLocation()
        local buttonPos = menuButton.AbsolutePosition
        local buttonSizeVec = menuButton.AbsoluteSize
        local menuPos = menuFrame.AbsolutePosition
        local menuSizeVec = menuFrame.AbsoluteSize
        
        local isClickOnButton = 
            mouse.X >= buttonPos.X and 
            mouse.X <= buttonPos.X + buttonSizeVec.X and
            mouse.Y >= buttonPos.Y and 
            mouse.Y <= buttonPos.Y + buttonSizeVec.Y
        
        local isClickOnMenu = 
            mouse.X >= menuPos.X and 
            mouse.X <= menuPos.X + menuSizeVec.X and
            mouse.Y >= menuPos.Y and 
            mouse.Y <= menuPos.Y + menuSizeVec.Y
        
        if not isClickOnButton and not isClickOnMenu then
            toggleMenu()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.Escape and isMenuOpen then
        toggleMenu()
    end
end)


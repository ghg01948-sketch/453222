            buttonFrame.Position = UDim2.new(0, 0, 0, elementY)
            buttonFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            buttonFrame.BorderSizePixel = 2
            buttonFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            buttonFrame.Parent = container
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -20, 0, 25)
            nameLabel.Position = UDim2.new(0, 10, 0, 5)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = buttonName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 16
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = buttonFrame
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -20, 0, 20)
            descLabel.Position = UDim2.new(0, 10, 0, 30)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = description or ""
            descLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
            descLabel.TextSize = 12
            descLabel.Font = Enum.Font.Code
